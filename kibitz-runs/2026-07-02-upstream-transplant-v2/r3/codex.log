v in data.items() if k != \"meta_mirrors\"}\r\n  38:     with pytest.raises(adapter.BridgeInputError, match=\"meta_mirrors\"):\r\n  39:         adapter.validate_bridge_artifact(broken)\r\n  40: \r\n  41:     twisted = _artifact_dict(registry)\r\n  42:     twisted[\"ledger_writing_spec\"][\"prompt_profile\"][\"story_model_id\"] = \"other\"\r\n  43:     with pytest.raises(adapter.BridgeInputError, match=\"prompt_profile\"):\r\n  44:         adapter.validate_bridge_artifact(twisted)\r\n  45: \r\n  46:     drifted = _artifact_dict(registry)\r\n  47:     drifted[\"meta_mirrors\"][\"news\"].pop(\"decoder_profile\")\r\n  48:     with pytest.raises(adapter.BridgeInputError, match=\"NewsBriefs\"):\r\n  49:         adapter.validate_bridge_artifact(drifted)\r\n  50: \r\n  51: \r\n  52: def test_profile_helpers_produce_locked_kwargs(registry) -> None:\r\n  53:     data = _artifact_dict(registry)\r\n  54:     profile = data[\"ledger_writing_spec\"][\"prompt_profile\"]\r\n  55:     outline = spp.outline_request_fields(profile)\r\n  56:     assert outline[\"source_material_label\"] == \"Media archive item\"\r\n  57:     overrides = spp.style_picker_overrides(profile)\r\n  58:     assert set(overrides) == {\r\n  59:         \"inventor_system_prompt\", \"chooser_system_prompt\", \"chooser_user_template\",\r\n  60:     }\r\n  61:     # Non-science lanes must OVERRIDE the production sci-fi inventor persona\r\n  62:     # (the pack prompt may still mention sci-fi as a negation; the leakage\r\n  63:     # scan governs term policy, not this test).\r\n  64:     assert overrides[\"inventor_system_prompt\"].strip()\r\n  65:     assert overrides[\"inventor_system_prompt\"] != \"You are a sci-fi radio drama showrunner.\"\r\n  66:     assert spp.coda_mode(profile) == \"archive_source_note\"\r\n  67: \r\n  68: \r\n  69: def test_science_profile_leaves_style_picker_constants(registry) -> None:\r\n  70:     data = _artifact_dict(registry, \"science_news\")\r\n  71:     profile = data[\"ledger_writing_spec\"][\"prompt_profile\"]\r\n  72:     overrides = spp.style_picker_overrides(profile)\r\n  73:     assert overrides == {\r\n  74:         \"inventor_system_prompt\": \"\",\r\n  75:         \"chooser_system_prompt\": \"\",\r\n  76:         \"chooser_user_template\": \"\",\r\n  77:     }  # empty = production module constants stay byte-identical\r\n  78: \r\n  79: \r\n  80: def test_visual_policy_stamp_and_tails(registry) -> None:\r\n  81:     data = _artifact_dict(registry)\r\n  82:     policy = data[\"ledger_writing_spec\"][\"visual_policy\"]\r\n  83:     meta: dict = {}\r\n  84:     vsp.stamp_meta(meta, policy)\r\n  85:     assert vsp.read_style_id(meta) == \"archival_documentary\"\r\n  86:     with pytest.raises(vsp.VisualPolicyError, match=\"refusing to restamp\"):\r\n  87:         vsp.stamp_meta({\"visual_style\": \"sci_fi_radio\"}, policy)\r\n  88:     tails = vsp.tail_overrides(policy)\r\n  89:     assert tails[\"style_tail\"]\r\n  90:     with pytest.raises(vsp.VisualPolicyError, match=\"unknown motion role\"):\r\n  91:         vsp.motion_prompt_for_role(policy, \"scene_broll\")\r\n  92: \r\n  93: \r\n  94: def test_facade_routes_and_refuses(registry) -> None:\r\n  95:     data = _artifact_dict(registry)\r\n  96:     story_input = data[\"ledger_writing_spec\"][\"story_input\"]\r\n  97:     out = facade.interpret_source(\"media_archive\", bridge_story_input=story_input)\r\n  98:     assert set(out) == set(facade.LOGICAL_FIELDS)\r\n  99: \r\n 100:     with pytest.raises(facade.SourceInterpreterError, match=\"packet-driven\"):\r\n 101:         facade.interpret_source(\"media_archive\")\r\n 102:     with pytest.raises(facade.SourceInterpreterError, match=\"news_briefs_builder\"):\r\n 103:         facade.interpret_source(\"science_news\")\r\n 104:     with pytest.raises(facade.SourceInterpreterError, match=\"not runnable\"):\r\n 105:         facade.interpret_source(\"custom_source_bank\")\r\n 106:     with pytest.raises(facade.SourceInterpreterError, match=\"cross-lane\"):\r\n 107:         facade.interpret_source(\"public_domain_story\", bridge_story_input=story_input)\r\n 108: \r\n 109: \r\n 110: def test_facade_science_wraps_builder_verbatim() -> None:\r\n 111:     class FakeBriefs:\r\n 112:         def model_dump(self):\r\n 113:             return {\r\n 114:                 \"casting_brief\": \"c\", \"script_brief\": \"s\",\r\n 115:                 \"news_close_brief\": \"n\", \"key_terms\": [\"k\"],\r\n 116:             }\r\n 117: \r\n 118:     calls = {}\r\n 119: \r\n 120:     def builder(article=None, **kwargs):\r\n 121:         calls[\"article\"] = article\r\n 122:         return FakeBriefs()\r\n 123: \r\n 124:     out = facade.interpret_source(\r\n 125:         \"science_news\", article={\"headline\": \"h\"}, news_briefs_builder=builder,\r\n 126:     )\r\n 127:     assert out[\"close_brief\"] == \"n\"\r\n 128:     assert calls[\"article\"] == {\"headline\": \"h\"}\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_28","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'tests\\\\test_bridge_and_runner.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Bridge artifact emission + simple_4 runner loud-failure contract.\"\"\"\r\n   2: \r\n   3: from __future__ import annotations\r\n   4: \r\n   5: import json\r\n   6: \r\n   7: import pytest\r\n   8: \r\n   9: from upstream_story_lab.bridge import (\r\n  10:     BridgeError,\r\n  11:     build_bridge_artifact,\r\n  12:     build_spec,\r\n  13:     emit_bridge_artifact,\r\n  14: )\r\n  15: from upstream_story_lab.compat import (\r\n  16:     NEWS_ARTICLE_KEYS,\r\n  17:     NEWS_BRIEFS_FIELDS,\r\n  18:     NEWS_SEED_KEYS,\r\n  19: )\r\n  20: from upstream_story_lab.contracts import BridgeArtifact\r\n  21: from upstream_story_lab.runner import PipelineRunError, run_pipeline\r\n  22: \r\n  23: \r\n  24: def test_bridge_mirrors_are_complete_and_mapped(registry) -> None:\r\n  25:     for bank in (\"science_news\", \"media_archive\", \"public_domain_story\"):\r\n  26:         spec = build_spec(registry, source_bank_id=bank)\r\n  27:         artifact = build_bridge_artifact(spec)\r\n  28:         news = artifact.meta_mirrors.news\r\n  29:         assert set(news) == set(NEWS_BRIEFS_FIELDS)\r\n  30:         assert isinstance(news[\"key_terms\"], list)  # freeze invariant\r\n  31:         # close_brief -> news_close_brief mapping is explicit\r\n  32:         assert news[\"news_close_brief\"] == spec.story_input.close_brief\r\n  33:         seed = artifact.meta_mirrors.news_seed\r\n  34:         assert set(seed) == set(NEWS_SEED_KEYS)\r\n  35:         article = artifact.adapter_news_article\r\n  36:         assert set(article) == set(NEWS_ARTICLE_KEYS)\r\n  37:         assert article[\"seed_text\"].strip()\r\n  38: \r\n  39: \r\n  40: def test_bridge_artifact_round_trips_to_disk(registry, tmp_path) -> None:\r\n  41:     spec = build_spec(registry, source_bank_id=\"media_archive\")\r\n  42:     artifact = build_bridge_artifact(spec)\r\n  43:     path = emit_bridge_artifact(artifact, tmp_path / \"bridge\" / \"artifact.json\")\r\n  44:     raw = path.read_bytes()\r\n  45:     assert not raw.startswith(b\"\\xef\\xbb\\xbf\")  # no BOM\r\n  46:     reparsed = BridgeArtifact(**json.loads(raw.decode(\"utf-8\")))\r\n  47:     assert reparsed.ledger_writing_spec.story_model_id == spec.story_model_id\r\n  48:     assert reparsed.ledger_writing_spec.provenance.pack_sha256\r\n  49: \r\n  50: \r\n  51: def test_bridge_refuses_empty_seed(registry) -> None:\r\n  52:     spec = build_spec(registry, source_bank_id=\"media_archive\")\r\n  53:     stripped = spec.model_copy(deep=True)\r\n  54:     stripped.source_material.source_title = \"\"\r\n  55:     stripped.source_material.source_summary = \"\"\r\n  56:     stripped.source_material.raw_text = \"\"\r\n  57:     with pytest.raises(BridgeError, match=\"no title/summary/raw_text\"):\r\n  58:         build_bridge_artifact(stripped)\r\n  59: \r\n  60: \r\n  61: # ---------------- simple_4 runner ----------------\r\n  62: \r\n  63: \r\n  64: def _experimental(registry):\r\n  65:     pack = registry.pack(\r\n  66:         \"custom_source_bank\", \"simple_4_prompt_experimental\",\r\n  67:         \"simple_4_prompt_experimental\",\r\n  68:     )\r\n  69:     pipeline = registry.pipeline(\"simple_4_prompt_experimental\")\r\n  70:     return pack, pipeline\r\n  71: \r\n  72: \r\n  73: def test_runner_happy_path_runs_all_four_passes(registry) -> None:\r\n  74:     pack, pipeline = _experimental(registry)\r\n  75:     calls = []\r\n  76: \r\n  77:     def fake_llm(slot, pass_id, prompt):\r\n  78:         calls.append((slot, pass_id))\r\n  79:         return f\"output for {pass_id}\"\r\n  80: \r\n  81:     outputs = run_pipeline(pack, pipeline, fake_llm)\r\n  82:     assert list(outputs) == [p.pass_id for p in pipeline.passes]\r\n  83:     assert [s for s, _ in calls] == [\"creative\", \"creative\", \"technical\", \"technical\"]\r\n  84: \r\n  85: \r\n  86: @pytest.mark.parametrize(\"fail_at\", [0, 1, 2, 3])\r\n  87: def test_runner_names_the_exact_failing_pass(registry, fail_at) -> None:\r\n  88:     pack, pipeline = _experimental(registry)\r\n  89:     target = pipeline.passes[fail_at].pass_id\r\n  90: \r\n  91:     def fake_llm(slot, pass_id, prompt):\r\n  92:         if pass_id == target:\r\n  93:             raise RuntimeError(\"model exploded\")\r\n  94:         return \"ok\"\r\n  95: \r\n  96:     with pytest.raises(PipelineRunError, match=target):\r\n  97:         run_pipeline(pack, pipeline, fake_llm)\r\n  98: \r\n  99: \r\n 100: def test_runner_refuses_descriptive_pipeline(registry) -> None:\r\n 101:     pack = registry.pack(\"media_archive\", \"gentle_thriller\", \"legacy_many_pass\")\r\n 102:     pipeline = registry.pipeline(\"legacy_many_pass\")\r\n 103:     with pytest.raises(PipelineRunError, match=\"descriptive\"):\r\n 104:         run_pipeline(pack, pipeline, lambda *a: \"ok\")\r\n 105: \r\n 106: \r\n 107: def test_runner_empty_output_fails_loud_no_fallback(registry) -> None:\r\n 108:     pack, pipeline = _experimental(registry)\r\n 109:     with pytest.raises(PipelineRunError, match=\"no fallback\"):\r\n 110:         run_pipeline(pack, pipeline, lambda *a: \"\")\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_30","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'tests\\\\test_matrix_and_leakage.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Declared-matrix invariants + story/visual leakage (kibitz r1/r2 scope:\r\n   2: valid pack pairs x styles + one typed negative per axis; no full Cartesian).\"\"\"\r\n   3: \r\n   4: from __future__ import annotations\r\n   5: \r\n   6: import time\r\n   7: \r\n   8: import pytest\r\n   9: \r\n  10: from upstream_story_lab.bridge import build_spec\r\n  11: from upstream_story_lab.compat import PRODUCTION_VISUAL_TAILS\r\n  12: from upstream_story_lab.preview import (\r\n  13:     render_prompt_preview,\r\n  14:     render_visual_preview,\r\n  15:     scan_story_leakage,\r\n  16:     scan_visual_leakage,\r\n  17: )\r\n  18: from upstream_story_lab.profiles import resolve_profile\r\n  19: from upstream_story_lab.registry import UnknownIdError\r\n  20: \r\n  21: RUNNABLE_BANKS = (\"science_news\", \"media_archive\", \"public_domain_story\")\r\n  22: \r\n  23: #: Terms no NON-SCIENCE story preview may contain (the science lane is the\r\n  24: #: only lane where science/news words are allowed).\r\n  25: NON_SCIENCE_STORY_LEAKAGE = (\r\n  26:     \"science-fiction audio drama\",\r\n  27:     \"sci-fi radio drama\",\r\n  28:     \"real science\",\r\n  29:     \"news facts\",\r\n  30:     \"spaceship\",\r\n  31:     \"mission control\",\r\n  32:     \"laboratory containment\",\r\n  33: )\r\n  34: \r\n  35: #: Visual terms the non-cinematic styles must never emit.\r\n  36: NON_CINEMA_VISUAL_LEAKAGE = (\"35mm\", \"film grain\", \"radio studio\")\r\n  37: \r\n  38: \r\n  39: def test_declared_matrix_resolves_and_previews(registry) -> None:\r\n  40:     \"\"\"Every runnable (bank, model, pipeline) pack x every style: resolution\r\n  41:     succeeds, profile builds, spec assembles, previews render. Budget <10s.\"\"\"\r\n  42: \r\n  43:     start = time.monotonic()\r\n  44:     combos = 0\r\n  45:     for (bank_id, model_id, pipeline_id), (pack, _path) in registry.packs.items():\r\n  46:         if bank_id not in RUNNABLE_BANKS:\r\n  47:             continue\r\n  48:         if not registry.pipeline(pipeline_id).executable_in_lab:\r\n  49:             # legacy_many_pass: still resolvable + previewable.\r\n  50:             pass\r\n  51:         for style_id in registry.styles:\r\n  52:             spec = build_spec(\r\n  53:                 registry,\r\n  54:                 source_bank_id=bank_id,\r\n  55:                 story_model_id=model_id,\r\n  56:                 story_pipeline_id=pipeline_id,\r\n  57:                 visual_style_id=style_id,\r\n  58:             )\r\n  59:             assert spec.story_model_id == model_id\r\n  60:             assert spec.visual_style_id == style_id\r\n  61:             assert render_prompt_preview(spec)\r\n  62:             assert render_visual_preview(spec)\r\n  63:             combos += 1\r\n  64:     assert combos >= 55  # 11 runnable-bank packs x 5 styles\r\n  65:     assert time.monotonic() - start < 10.0\r\n  66: \r\n  67: \r\n  68: def test_auto_defaults_are_recorded_not_invisible(registry) -> None:\r\n  69:     spec = build_spec(registry, source_bank_id=\"media_archive\")\r\n  70:     decisions = {d.axis: d for d in spec.resolution.decisions}\r\n  71:     assert decisions[\"story_model\"].default_applied is True\r\n  72:     assert decisions[\"story_model\"].decided_by == \"banks.json:default_story_model\"\r\n  73:     assert decisions[\"visual_style\"].resolved == \"archival_documentary\"\r\n  74:     assert spec.provenance.pack_sha256 and spec.provenance.banks_sha256\r\n  75: \r\n  76: \r\n  77: def test_one_negative_per_axis(registry) -> None:\r\n  78:     with pytest.raises(UnknownIdError):\r\n  79:         registry.resolve(source_bank_id=\"unknown_bank\")\r\n  80:     with pytest.raises(UnknownIdError):\r\n  81:         registry.resolve(source_bank_id=\"media_archive\", story_model_id=\"space_opera\")\r\n  82:     with pytest.raises(UnknownIdError):\r\n  83:         registry.resolve(source_bank_id=\"media_archive\", story_pipeline_id=\"mystery_pipe\")\r\n  84:     with pytest.raises(UnknownIdError):\r\n  85:         registry.resolve(source_bank_id=\"media_archive\", visual_style_id=\"vaporwave\")\r\n  86: \r\n  87: \r\n  88: def test_non_science_story_previews_are_clean(registry) -> None:\r\n  89:     for (bank_id, model_id, pipeline_id), _ in registry.packs.items():\r\n  90:         if bank_id not in (\"media_archive\", \"public_domain_story\"):\r\n  91:             continue\r\n  92:         spec = build_spec(\r\n  93:             registry, source_bank_id=bank_id, story_model_id=model_id,\r\n  94:             story_pipeline_id=pipeline_id,\r\n  95:         )\r\n  96:         preview = render_prompt_preview(spec).lower()\r\n  97:         hits = [t for t in NON_SCIENCE_STORY_LEAKAGE if t in preview]\r\n  98:         assert not hits, f\"{bank_id}/{model_id} leaked {hits}\"\r\n  99:         assert not scan_story_leakage(registry, spec)\r\n 100: \r\n 101: \r\n 102: def test_science_lane_still_speaks_science(registry) -> None:\r\n 103:     profile = resolve_profile(registry, \"science_news\", \"science_news_default\",\r\n 104:                               \"legacy_many_pass\")\r\n 105:     assert \"science\" in profile.story_form_label\r\n 106:     assert profile.coda_mode == \"real_news_report\"\r\n 107: \r\n 108: \r\n 109: def test_non_cinematic_styles_emit_no_cinema_tails(registry) -> None:\r\n 110:     for style_id in (\"anime\", \"cartoon\", \"paper_origami\"):\r\n 111:         spec = build_spec(\r\n 112:             registry, source_bank_id=\"media_archive\", visual_style_id=style_id,\r\n 113:         )\r\n 114:         preview = render_visual_preview(spec).lower()\r\n 115:         hits = [t for t in NON_CINEMA_VISUAL_LEAKAGE if t in preview]\r\n 116:         assert not hits, f\"{style_id} leaked {hits}\"\r\n 117:         assert not scan_visual_leakage(spec)\r\n 118: \r\n 119: \r\n 120: def test_sci_fi_radio_reproduces_production_tails_byte_identically(registry) -> None:\r\n 121:     policy = registry.style(\"sci_fi_radio\")\r\n 122:     assert policy.era_tail == PRODUCTION_VISUAL_TAILS[\"ERA_TAIL_DEFAULT\"]\r\n 123:     assert policy.positive_tail == PRODUCTION_VISUAL_TAILS[\"STYLE_TAIL_DEFAULT\"]\r\n 124:     assert policy.image_grade_tail == PRODUCTION_VISUAL_TAILS[\"IMAGE_GRADE_TAIL\"]\r\n 125:     assert policy.broadcast_tail == PRODUCTION_VISUAL_TAILS[\"RADIO_BROADCAST_TAIL\"]\r\n 126:     assert policy.allow_radio_tails is True\r\n 127: \r\n 128: \r\n 129: def test_archival_documentary_motion_keys_match_production_vocabulary(registry) -> None:\r\n 130:     policy = registry.style(\"archival_documentary\")\r\n 131:     assert set(policy.motion_prompts) == {\r\n 132:         \"announcer\", \"music_open\", \"music_close\", \"music_inter\",\r\n 133:     }\r\n","exit_code":0,"status":"completed"}}
