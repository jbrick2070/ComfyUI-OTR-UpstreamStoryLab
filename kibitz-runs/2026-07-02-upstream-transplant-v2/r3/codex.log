{"type":"item.completed","item":{"id":"item_34","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'scripts\\\\validate_lab.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Headless validation of the upstream story lab v2 (CI/sandbox use, no\r\n   2: ComfyUI required - kept per kibitz r1 judgment).\"\"\"\r\n   3: \r\n   4: from __future__ import annotations\r\n   5: \r\n   6: import sys\r\n   7: from pathlib import Path\r\n   8: \r\n   9: ROOT = Path(__file__).resolve().parents[1]\r\n  10: SRC = ROOT / \"src\"\r\n  11: sys.path.insert(0, str(SRC))\r\n  12: \r\n  13: from upstream_story_lab.bridge import build_bridge_artifact, build_spec  # noqa: E402\r\n  14: from upstream_story_lab.compat import (  # noqa: E402\r\n  15:     MOTION_ROLE_KEYS,\r\n  16:     NEWS_BRIEFS_FIELDS,\r\n  17:     NEWS_SEED_KEYS,\r\n  18:     PRODUCTION_VISUAL_TAILS,\r\n  19:     extract_motion_role_keys,\r\n  20:     extract_news_briefs_fields,\r\n  21:     extract_news_seed_keys,\r\n  22:     extract_visual_tails,\r\n  23: )\r\n  24: from upstream_story_lab.preview import (  # noqa: E402\r\n  25:     scan_story_leakage,\r\n  26:     scan_visual_leakage,\r\n  27: )\r\n  28: from upstream_story_lab.registry import Registry  # noqa: E402\r\n  29: \r\n  30: \r\n  31: def main() -> int:\r\n  32:     registry = Registry(ROOT)\r\n  33:     mirror = ROOT / \"production_mirror\" / \"nodes\"\r\n  34: \r\n  35:     assert tuple(extract_news_briefs_fields(mirror / \"news_interpreter.py\")) == NEWS_BRIEFS_FIELDS\r\n  36:     assert tuple(extract_news_seed_keys(mirror / \"_otr_legacy_to_stage1_adapter.py\")) == NEWS_SEED_KEYS\r\n  37:     assert tuple(extract_motion_role_keys(mirror / \"_otr_video_engines\" / \"render_driver.py\")) == MOTION_ROLE_KEYS\r\n  38:     assert extract_visual_tails(mirror / \"_otr_story_brief_helpers.py\") == PRODUCTION_VISUAL_TAILS\r\n  39: \r\n  40:     specs = 0\r\n  41:     for (bank_id, model_id, pipeline_id), _ in sorted(registry.packs.items()):\r\n  42:         if bank_id == \"custom_source_bank\":\r\n  43:             continue\r\n  44:         spec = build_spec(\r\n  45:             registry, source_bank_id=bank_id, story_model_id=model_id,\r\n  46:             story_pipeline_id=pipeline_id,\r\n  47:         )\r\n  48:         if bank_id != \"science_news\":\r\n  49:             leaked = scan_story_leakage(registry, spec)\r\n  50:             assert not leaked, f\"{bank_id}/{model_id} leaked {leaked}\"\r\n  51:         leaked_visual = scan_visual_leakage(spec)\r\n  52:         assert not leaked_visual, f\"{bank_id}/{model_id} visual leaked {leaked_visual}\"\r\n  53:         build_bridge_artifact(spec)\r\n  54:         specs += 1\r\n  55: \r\n  56:     manifests = registry.public_domain_manifests()\r\n  57: \r\n  58:     print(\"OK upstream_story_lab v2\")\r\n  59:     print(f\"banks={sorted(registry.banks)}\")\r\n  60:     print(f\"story_packs={len(registry.packs)}\")\r\n  61:     print(f\"validated_specs={specs}\")\r\n  62:     print(f\"visual_styles={sorted(registry.styles)}\")\r\n  63:     print(f\"public_domain_manifests={len(manifests)}\")\r\n  64:     print(\"mirror_drift=none\")\r\n  65:     return 0\r\n  66: \r\n  67: \r\n  68: if __name__ == \"__main__\":\r\n  69:     raise SystemExit(main())\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_35","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'src\\\\upstream_story_lab\\\\preview.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Prompt preview rendering + pack-driven leakage scanning.\r\n   2: \r\n   3: Forbidden terms are pack content (JSON), scanned against RENDERED previews;\r\n   4: they are never rendered into live prompts (models copy negated terms - the\r\n   5: metadata-not-prompt rule, kept from v1).\r\n   6: \"\"\"\r\n   7: \r\n   8: from __future__ import annotations\r\n   9: \r\n  10: from .contracts import LedgerWritingSpec\r\n  11: \r\n  12: \r\n  13: def render_prompt_preview(spec: LedgerWritingSpec) -> str:\r\n  14:     \"\"\"A flat preview of the prose the ledger-writing stages would see.\"\"\"\r\n  15: \r\n  16:     profile = spec.prompt_profile\r\n  17:     parts = [\r\n  18:         profile.outline_system_prompt or \"\",\r\n  19:         profile.pitch_room_system_prompt or \"\",\r\n  20:         profile.story_select_system_prompt or \"\",\r\n  21:         profile.dramatic_state_system_prompt or \"\",\r\n  22:         profile.coda_system_prompt or \"\",\r\n  23:         profile.title_system_prompt or \"\",\r\n  24:         f\"Story form: {profile.story_form_label}\",\r\n  25:         f\"Source material: {profile.source_material_label}\",\r\n  26:         f\"Develop verb: {profile.source_develop_verb}\",\r\n  27:         f\"Grounding: {profile.source_grounding_label}\",\r\n  28:         f\"Line instruction: {profile.line_grounding_instruction}\",\r\n  29:         \"Tone guardrails: \" + \"; \".join(profile.tone_guardrails),\r\n  30:         # Forbidden patterns stay metadata: count only, never the phrases.\r\n  31:         f\"Forbidden pattern count: {len(profile.forbidden_plot_patterns)}\",\r\n  32:     ]\r\n  33:     return \"\\n\".join(p for p in parts if p)\r\n  34: \r\n  35: \r\n  36: def render_visual_preview(spec: LedgerWritingSpec) -> str:\r\n  37:     \"\"\"A flat preview of the visual language a policy would emit.\"\"\"\r\n  38: \r\n  39:     policy = spec.visual_policy\r\n  40:     parts = [\r\n  41:         policy.positive_tail,\r\n  42:         policy.image_grade_tail,\r\n  43:         policy.broadcast_tail,\r\n  44:         policy.era_tail,\r\n  45:         policy.announcer_visual_subject,\r\n  46:         policy.music_visual_subject,\r\n  47:         policy.scene_open_subject,\r\n  48:         policy.character_portrait_style,\r\n  49:         policy.character_scene_style,\r\n  50:         *policy.motion_prompts.values(),\r\n  51:     ]\r\n  52:     return \"\\n\".join(p for p in parts if p)\r\n  53: \r\n  54: \r\n  55: def find_forbidden_terms(text: str, terms: list[str]) -> list[str]:\r\n  56:     \"\"\"Case-insensitive containment scan; the term list comes from the pack\r\n  57:     or policy JSON, never from a Python constant.\"\"\"\r\n  58: \r\n  59:     low = (text or \"\").lower()\r\n  60:     return [term for term in terms if term.lower() in low]\r\n  61: \r\n  62: \r\n  63: def scan_story_leakage(registry, spec: LedgerWritingSpec) -> list[str]:\r\n  64:     \"\"\"Leakage terms found in the story prompt preview. The term list is the\r\n  65:     ACTIVE PACK's forbidden_leakage_terms (pack JSON metadata) - scanned for\r\n  66:     every bank that declares terms, not just media archive.\"\"\"\r\n  67: \r\n  68:     pack = registry.pack(\r\n  69:         spec.source_bank_id, spec.story_model_id, spec.story_pipeline_id\r\n  70:     )\r\n  71:     return find_forbidden_terms(\r\n  72:         render_prompt_preview(spec), list(pack.forbidden_leakage_terms)\r\n  73:     )\r\n  74: \r\n  75: \r\n  76: def scan_visual_leakage(spec: LedgerWritingSpec) -> list[str]:\r\n  77:     \"\"\"Forbidden visual terms found in the rendered visual preview (the term\r\n  78:     list is the policy's own forbidden_terms).\"\"\"\r\n  79: \r\n  80:     return find_forbidden_terms(\r\n  81:         render_visual_preview(spec), list(spec.visual_policy.forbidden_terms)\r\n  82:     )\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_32","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'src\\\\upstream_story_lab\\\\profiles.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Pack -> resolved StoryPromptProfile. Validation and merging only.\r\n   2: \r\n   3: The profile is a RESOLVED VIEW of (bank defaults + pack). Every string in it\r\n   4: comes from JSON; this module never invents prose. Missing required content is\r\n   5: a hard error naming the pack file.\r\n   6: \"\"\"\r\n   7: \r\n   8: from __future__ import annotations\r\n   9: \r\n  10: from .contracts import (\r\n  11:     CODA_MODES,\r\n  12:     BankDefaults,\r\n  13:     SourceBankSpec,\r\n  14:     StoryPack,\r\n  15:     StoryPromptProfile,\r\n  16: )\r\n  17: from .registry import Registry, RegistryError\r\n  18: \r\n  19: \r\n  20: def _merged_labels(bank: SourceBankSpec, pack: StoryPack) -> BankDefaults:\r\n  21:     \"\"\"Single-level merge: pack label overrides bank default when non-empty.\"\"\"\r\n  22: \r\n  23:     merged = {}\r\n  24:     for field in BankDefaults.model_fields:\r\n  25:         pack_value = getattr(pack.labels, field)\r\n  26:         bank_value = getattr(bank.defaults, field)\r\n  27:         merged[field] = pack_value if str(pack_value).strip() else bank_value\r\n  28:     return BankDefaults(**merged)\r\n  29: \r\n  30: \r\n  31: def resolve_profile(registry: Registry, source_bank_id: str, story_model_id: str,\r\n  32:                     story_pipeline_id: str) -> StoryPromptProfile:\r\n  33:     bank = registry.bank(source_bank_id)\r\n  34:     pack = registry.pack(source_bank_id, story_model_id, story_pipeline_id)\r\n  35:     pack_path = registry.pack_path(source_bank_id, story_model_id, story_pipeline_id)\r\n  36:     labels = _merged_labels(bank, pack)\r\n  37: \r\n  38:     coda_mode = (pack.coda_mode or labels.coda_mode or \"\").strip()\r\n  39:     if coda_mode not in CODA_MODES:\r\n  40:         raise RegistryError(\r\n  41:             f\"{pack_path}: no valid coda_mode resolved (pack={pack.coda_mode!r}, \"\r\n  42:             f\"bank default={bank.defaults.coda_mode!r}); allowed: {CODA_MODES}. \"\r\n  43:             \"No default coda is invented.\"\r\n  44:         )\r\n  45: \r\n  46:     required_labels = (\r\n  47:         \"story_form_label\",\r\n  48:         \"source_material_label\",\r\n  49:         \"source_develop_verb\",\r\n  50:         \"source_grounding_label\",\r\n  51:         \"title_form_label\",\r\n  52:     )\r\n  53:     missing = [f for f in required_labels if not str(getattr(labels, f)).strip()]\r\n  54:     if missing:\r\n  55:         raise RegistryError(\r\n  56:             f\"{pack_path}: unresolved required labels {missing} - supply them in \"\r\n  57:             \"the pack labels block or the bank defaults (JSON owns content).\"\r\n  58:         )\r\n  59: \r\n  60:     line_grounding = pack.prompt_stages.get(\"line_grounding\", \"\").strip()\r\n  61:     if not line_grounding:\r\n  62:         raise RegistryError(\r\n  63:             f\"{pack_path}: prompt_stages.line_grounding is required and empty - \"\r\n  64:             \"no grounding instruction is invented in Python.\"\r\n  65:         )\r\n  66: \r\n  67:     def stage(name: str) -> str | None:\r\n  68:         value = pack.prompt_stages.get(name, \"\").strip()\r\n  69:         return value or None\r\n  70: \r\n  71:     return StoryPromptProfile(\r\n  72:         source_bank_id=bank.source_bank_id,\r\n  73:         story_model_id=pack.story_model_id,\r\n  74:         story_form_label=labels.story_form_label,\r\n  75:         source_material_label=labels.source_material_label,\r\n  76:         source_develop_verb=labels.source_develop_verb,\r\n  77:         source_grounding_label=labels.source_grounding_label,\r\n  78:         key_terms_label=labels.key_terms_label,\r\n  79:         close_brief_label=labels.close_brief_label,\r\n  80:         coda_mode=coda_mode,  # type: ignore[arg-type]\r\n  81:         title_form_label=labels.title_form_label,\r\n  82:         line_grounding_instruction=line_grounding,\r\n  83:         outline_rules_extra=pack.outline_rules_extra,\r\n  84:         tone_guardrails=list(pack.tone_guardrails),\r\n  85:         forbidden_plot_patterns=list(pack.forbidden_plot_patterns),\r\n  86:         outline_system_prompt=stage(\"outline_system\"),\r\n  87:         pitch_room_system_prompt=stage(\"pitch_room_system\"),\r\n  88:         story_select_system_prompt=stage(\"story_select_system\"),\r\n  89:         dramatic_state_system_prompt=stage(\"dramatic_state_system\"),\r\n  90:         coda_system_prompt=stage(\"coda_system\"),\r\n  91:         coda_examples=list(pack.coda_examples),\r\n  92:         title_system_prompt=stage(\"title_system\"),\r\n  93:         style_picker_inventor_system_prompt=stage(\"style_pick_inventor\"),\r\n  94:         style_picker_chooser_system_prompt=stage(\"style_pick_chooser\"),\r\n  95:         style_picker_chooser_user_template=stage(\"style_pick_chooser_user_template\"),\r\n  96:     )\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_33","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'src\\\\upstream_story_lab\\\\interpreters.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Source interpreter bindings: named, allowlisted, declared in banks.json.\r\n   2: \r\n   3: Protocol (kibitz r1):\r\n   4: \r\n   5:     interpret_source(packet, bank, llm_fns) -> StoryInputPacket\r\n   6: \r\n   7: Fixture interpreters are DETERMINISTIC PLUMBING: they validate and assemble\r\n   8: content that lives in the source packet JSON (fixture_* fields). They never\r\n   9: author prose. At transplant, the science bank's production interpreter wraps\r\n  10: news_interpreter.build_news_briefs verbatim and maps NewsBriefs ->\r\n  11: StoryInputPacket; that binding is registered production-side, not here.\r\n  12: \"\"\"\r\n  13: \r\n  14: from __future__ import annotations\r\n  15: \r\n  16: from typing import Any, Callable\r\n  17: \r\n  18: from .contracts import SourceBankSpec, SourceMaterialPacket, StoryInputPacket\r\n  19: \r\n  20: \r\n  21: class InterpreterError(ValueError):\r\n  22:     \"\"\"Fail-loud interpreter problem (missing content, wrong bank).\"\"\"\r\n  23: \r\n  24: \r\n  25: #: Optional LLM callables a production interpreter may use. Fixture\r\n  26: #: interpreters ignore them (network/model-free by design).\r\n  27: LlmFns = dict[str, Callable[..., Any]]\r\n  28: \r\n  29: \r\n  30: def _require(packet: SourceMaterialPacket, field: str) -> str:\r\n  31:     value = str(getattr(packet, field, \"\")).strip()\r\n  32:     if not value:\r\n  33:         raise InterpreterError(\r\n  34:             f\"source packet for bank {packet.source_bank_id!r} is missing \"\r\n  35:             f\"required fixture content field {field!r} - author it in the \"\r\n  36:             \"packet JSON (JSON owns content; no prose is invented here).\"\r\n  37:         )\r\n  38:     return value\r\n  39: \r\n  40: \r\n  41: def _base_kwargs(packet: SourceMaterialPacket, story_model_id: str) -> dict[str, Any]:\r\n  42:     return {\r\n  43:         \"source_bank_id\": packet.source_bank_id,\r\n  44:         \"story_model_id\": story_model_id,\r\n  45:         \"source_label\": packet.source_label,\r\n  46:         \"casting_brief\": _require(packet, \"fixture_casting_brief\"),\r\n  47:         \"script_brief\": (\r\n  48:             packet.fixture_script_brief.strip()\r\n  49:             or packet.source_summary.strip()\r\n  50:             or _require(packet, \"fixture_script_brief\")\r\n  51:         ),\r\n  52:         \"close_brief\": _require(packet, \"fixture_close_brief\"),\r\n  53:         \"key_terms\": list(packet.fixture_key_terms),\r\n  54:         \"source_fidelity_rules\": list(packet.fixture_fidelity_rules),\r\n  55:         \"source_material\": packet,\r\n  56:     }\r\n  57: \r\n  58: \r\n  59: def interpret_fixture_science_news(packet: SourceMaterialPacket,\r\n  60:                                    bank: SourceBankSpec,\r\n  61:                                    llm_fns: LlmFns | None = None,\r\n  62:                                    *, story_model_id: str) -> StoryInputPacket:\r\n  63:     if packet.source_bank_id != \"science_news\":\r\n  64:         raise InterpreterError(\r\n  65:             f\"science interpreter got bank {packet.source_bank_id!r}\"\r\n  66:         )\r\n  67:     kwargs = _base_kwargs(packet, story_model_id)\r\n  68:     if not kwargs[\"key_terms\"]:\r\n  69:         raise InterpreterError(\r\n  70:             \"science fixture packet must carry fixture_key_terms (>=1); the \"\r\n  71:             \"production lane guarantees key_terms via NewsBriefs\"\r\n  72:         )\r\n  73:     kwargs[\"adaptation_trace\"] = {\"fixture\": True, \"story_model_id\": story_model_id}\r\n  74:     return StoryInputPacket(**kwargs)\r\n  75: \r\n  76: \r\n  77: def interpret_fixture_media_archive(packet: SourceMaterialPacket,\r\n  78:                                     bank: SourceBankSpec,\r\n  79:                                     llm_fns: LlmFns | None = None,\r\n  80:                                     *, story_model_id: str) -> StoryInputPacket:\r\n  81:     if packet.source_bank_id != \"media_archive\":\r\n  82:         raise InterpreterError(\r\n  83:             f\"media_archive interpreter got bank {packet.source_bank_id!r}\"\r\n  84:         )\r\n  85:     kwargs = _base_kwargs(packet, story_model_id)\r\n  86:     kwargs[\"adaptation_trace\"] = {\"fixture\": True, \"story_model_id\": story_model_id}\r\n  87:     return StoryInputPacket(**kwargs)\r\n  88: \r\n  89: \r\n  90: def interpret_fixture_public_domain(packet: SourceMaterialPacket,\r\n  91:                                     bank: SourceBankSpec,\r\n  92:                                     llm_fns: LlmFns | None = None,\r\n  93:                                     *, story_model_id: str) -> StoryInputPacket:\r\n  94:     if packet.source_bank_id != \"public_domain_story\":\r\n  95:         raise InterpreterError(\r\n  96:             f\"public_domain interpreter got bank {packet.source_bank_id!r}\"\r\n  97:         )\r\n  98:     if packet.rights_status != \"public_domain\":\r\n  99:         raise InterpreterError(\r\n 100:             f\"public_domain packet has rights_status {packet.rights_status!r}; \"\r\n 101:             \"only 'public_domain' is allowed in this lane\"\r\n 102:         )\r\n 103:     kwargs = _base_kwargs(packet, story_model_id)\r\n 104:     if not (packet.raw_text.strip() or packet.source_text_ref.strip()):\r\n 105:         raise InterpreterError(\r\n 106:             \"public_domain packet must carry raw_text or source_text_ref\"\r\n 107:         )\r\n 108:     kwargs[\"script_brief\"] = packet.raw_text.strip() or kwargs[\"script_brief\"]\r\n 109:     kwargs[\"adaptation_trace\"] = {\r\n 110:         \"fixture\": True,\r\n 111:         \"story_model_id\": story_model_id,\r\n 112:         \"source_kind\": packet.source_kind,\r\n 113:     }\r\n 114:     return StoryInputPacket(**kwargs)\r\n 115: \r\n 116: \r\n 117: #: The explicit binding allowlist. banks.json names one of these; an unknown\r\n 118: #: binding is a hard error naming the bank (no hidden engines).\r\n 119: INTERPRETER_BINDINGS: dict[str, Callable[..., StoryInputPacket]] = {\r\n 120:     \"fixture_science_news\": interpret_fixture_science_news,\r\n 121:     \"fixture_media_archive\": interpret_fixture_media_archive,\r\n 122:     \"fixture_public_domain\": interpret_fixture_public_domain,\r\n 123: }\r\n 124: \r\n 125: \r\n 126: def resolve_interpreter(bank: SourceBankSpec) -> Callable[..., StoryInputPacket]:\r\n 127:     binding = (bank.interpreter or \"\").strip()\r\n 128:     try:\r\n 129:         return INTERPRETER_BINDINGS[binding]\r\n 130:     except KeyError as exc:\r\n 131:         raise InterpreterError(\r\n 132:             f\"bank {bank.source_bank_id!r} declares unknown interpreter binding \"\r\n 133:             f\"{binding!r}; allowlist: {sorted(INTERPRETER_BINDINGS)}\"\r\n 134:         ) from exc\r\n","exit_code":0,"status":"completed"}}
