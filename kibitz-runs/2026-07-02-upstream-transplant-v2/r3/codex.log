{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'transplant_work\\\\production_new_modules\\\\_otr_visual_style_policy.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Production-side VisualStylePolicy reader + meta.visual_style helpers.\r\n   2: \r\n   3: DESTINATION: ComfyUI-OldTimeRadio/nodes/_otr_visual_style_policy.py\r\n   4: STATUS: staged in the lab (transplant_work/); NOT installed yet.\r\n   5: \r\n   6: The visual stage is SEPARATE and staged (locked pre-SFX r4 decision +\r\n   7: TRANSPLANT_MANIFEST risk note). This module only defines the policy reader,\r\n   8: the meta stamp/read helpers, and the tail accessors the shared seams\r\n   9: (finish_visual_prompt / compose_still_prompt) will consult. sci_fi_radio\r\n  10: must reproduce the current production constants byte-identically, so wiring\r\n  11: it changes nothing until a non-default style is selected.\r\n  12: \"\"\"\r\n  13: \r\n  14: from __future__ import annotations\r\n  15: \r\n  16: from typing import Any\r\n  17: \r\n  18: #: Production motion-prompt role vocabulary (render_driver). Dead roles\r\n  19: #: (sfx / scene_broll / background_abstract) must stay dead.\r\n  20: ALLOWED_MOTION_ROLE_KEYS = frozenset(\r\n  21:     {\"announcer\", \"music_open\", \"music_close\", \"music_inter\"}\r\n  22: )\r\n  23: \r\n  24: META_KEY = \"visual_style\"\r\n  25: \r\n  26: \r\n  27: class VisualPolicyError(ValueError):\r\n  28:     \"\"\"The policy dict is unusable or a dead role was requested.\"\"\"\r\n  29: \r\n  30: \r\n  31: REQUIRED_POLICY_FIELDS = (\"style_id\",)\r\n  32: \r\n  33: \r\n  34: def validate_policy(policy: dict[str, Any]) -> dict[str, Any]:\r\n  35:     if not isinstance(policy, dict):\r\n  36:         raise VisualPolicyError(\"visual_policy must be an object\")\r\n  37:     missing = [\r\n  38:         f for f in REQUIRED_POLICY_FIELDS if not str(policy.get(f, \"\")).strip()\r\n  39:     ]\r\n  40:     if missing:\r\n  41:         raise VisualPolicyError(f\"visual_policy missing required fields: {missing}\")\r\n  42:     unknown = sorted(\r\n  43:         set(policy.get(\"motion_prompts\", {})) - ALLOWED_MOTION_ROLE_KEYS\r\n  44:     )\r\n  45:     if unknown:\r\n  46:         raise VisualPolicyError(\r\n  47:             f\"visual_policy {policy['style_id']!r} motion_prompts has unknown \"\r\n  48:             f\"role keys {unknown} (dead roles must stay dead)\"\r\n  49:         )\r\n  50:     return policy\r\n  51: \r\n  52: \r\n  53: def stamp_meta(meta: dict[str, Any], policy: dict[str, Any]) -> dict[str, Any]:\r\n  54:     \"\"\"Stamp meta.visual_style = style_id. Refuses to overwrite a DIFFERENT\r\n  55:     existing stamp (two stamps disagreeing is a wiring bug, not a preference).\"\"\"\r\n  56: \r\n  57:     policy = validate_policy(policy)\r\n  58:     existing = str(meta.get(META_KEY, \"\") or \"\")\r\n  59:     style_id = policy[\"style_id\"]\r\n  60:     if existing and existing != style_id:\r\n  61:         raise VisualPolicyError(\r\n  62:             f\"meta.visual_style already stamped {existing!r}; refusing to \"\r\n  63:             f\"restamp {style_id!r}\"\r\n  64:         )\r\n  65:     meta[META_KEY] = style_id\r\n  66:     return meta\r\n  67: \r\n  68: \r\n  69: def read_style_id(meta: dict[str, Any]) -> str:\r\n  70:     \"\"\"Read the stamped style id; empty string means 'pre-transplant ledger'\r\n  71:     and callers keep current production behavior (sci_fi_radio constants).\"\"\"\r\n  72: \r\n  73:     return str((meta or {}).get(META_KEY, \"\") or \"\")\r\n  74: \r\n  75: \r\n  76: def tail_overrides(policy: dict[str, Any]) -> dict[str, str]:\r\n  77:     \"\"\"The four tail replacements the shared seams consult. Empty string =\r\n  78:     keep the production constant (sci_fi_radio supplies the SAME strings, so\r\n  79:     default behavior is byte-identical either way).\"\"\"\r\n  80: \r\n  81:     policy = validate_policy(policy)\r\n  82:     return {\r\n  83:         \"era_tail\": str(policy.get(\"era_tail\", \"\") or \"\"),\r\n  84:         \"style_tail\": str(policy.get(\"positive_tail\", \"\") or \"\"),\r\n  85:         \"image_grade_tail\": str(policy.get(\"image_grade_tail\", \"\") or \"\"),\r\n  86:         \"radio_broadcast_tail\": str(policy.get(\"broadcast_tail\", \"\") or \"\"),\r\n  87:     }\r\n  88: \r\n  89: \r\n  90: def allow_radio_tails(policy: dict[str, Any]) -> bool:\r\n  91:     return bool(validate_policy(policy).get(\"allow_radio_tails\", True))\r\n  92: \r\n  93: \r\n  94: def motion_prompt_for_role(policy: dict[str, Any], role: str) -> str:\r\n  95:     \"\"\"Motion prompt for a role. Missing role = empty string (caller keeps\r\n  96:     the production _LTX table); UNKNOWN/dead role = loud error.\"\"\"\r\n  97: \r\n  98:     policy = validate_policy(policy)\r\n  99:     if role not in ALLOWED_MOTION_ROLE_KEYS:\r\n 100:         raise VisualPolicyError(\r\n 101:             f\"unknown motion role {role!r}; allowed: {sorted(ALLOWED_MOTION_ROLE_KEYS)}\"\r\n 102:         )\r\n 103:     return str(policy.get(\"motion_prompts\", {}).get(role, \"\") or \"\")\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'transplant_work\\\\production_new_modules\\\\_otr_story_prompt_profile.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Production-side StoryPromptProfile consumption helpers.\r\n   2: \r\n   3: DESTINATION: ComfyUI-OldTimeRadio/nodes/_otr_story_prompt_profile.py\r\n   4: STATUS: staged in the lab (transplant_work/); NOT installed yet.\r\n   5: \r\n   6: Field names are locked to the pre-SFX r4 vocabulary. The helpers return\r\n   7: exactly the kwargs the locked transplant plan threads into production seams:\r\n   8: \r\n   9: - OutlineRequest fields (labels/verbs/rules) - profile persona prompts stay\r\n  10:   separate (locked decision: profile holds persona overrides, OutlineRequest\r\n  11:   holds label fields).\r\n  12: - pick_style(...) override kwargs (empty string = keep science/module\r\n  13:   constants; non-empty = pack-owned persona).\r\n  14: - compose_source_coda routing by coda_mode (science implementation remains\r\n  15:   compose_news_coda; other modes fail loud until their composers land).\r\n  16: \"\"\"\r\n  17: \r\n  18: from __future__ import annotations\r\n  19: \r\n  20: from typing import Any\r\n  21: \r\n  22: VALID_CODA_MODES = (\r\n  23:     \"real_news_report\", \"archive_source_note\", \"source_attribution\", \"none\",\r\n  24: )\r\n  25: \r\n  26: \r\n  27: class ProfileInputError(ValueError):\r\n  28:     \"\"\"The supplied profile dict is unusable; message names the field.\"\"\"\r\n  29: \r\n  30: \r\n  31: REQUIRED_PROFILE_FIELDS = (\r\n  32:     \"source_bank_id\",\r\n  33:     \"story_model_id\",\r\n  34:     \"story_form_label\",\r\n  35:     \"source_material_label\",\r\n  36:     \"source_develop_verb\",\r\n  37:     \"source_grounding_label\",\r\n  38:     \"coda_mode\",\r\n  39:     \"title_form_label\",\r\n  40:     \"line_grounding_instruction\",\r\n  41: )\r\n  42: \r\n  43: \r\n  44: def validate_profile(profile: dict[str, Any]) -> dict[str, Any]:\r\n  45:     if not isinstance(profile, dict):\r\n  46:         raise ProfileInputError(\"prompt_profile must be an object\")\r\n  47:     missing = [\r\n  48:         f for f in REQUIRED_PROFILE_FIELDS if not str(profile.get(f, \"\")).strip()\r\n  49:     ]\r\n  50:     if missing:\r\n  51:         raise ProfileInputError(f\"prompt_profile missing required fields: {missing}\")\r\n  52:     if profile[\"coda_mode\"] not in VALID_CODA_MODES:\r\n  53:         raise ProfileInputError(\r\n  54:             f\"prompt_profile.coda_mode {profile['coda_mode']!r} not in \"\r\n  55:             f\"{VALID_CODA_MODES}\"\r\n  56:         )\r\n  57:     return profile\r\n  58: \r\n  59: \r\n  60: def outline_request_fields(profile: dict[str, Any]) -> dict[str, Any]:\r\n  61:     \"\"\"Kwargs for OutlineRequest (label/verb/rule fields; keyword-defaulted\r\n  62:     only per the locked plan - never positional).\"\"\"\r\n  63: \r\n  64:     profile = validate_profile(profile)\r\n  65:     return {\r\n  66:         \"story_form_label\": profile[\"story_form_label\"],\r\n  67:         \"source_material_label\": profile[\"source_material_label\"],\r\n  68:         \"source_develop_verb\": profile[\"source_develop_verb\"],\r\n  69:         \"source_grounding_label\": profile[\"source_grounding_label\"],\r\n  70:         \"outline_rules_extra\": profile.get(\"outline_rules_extra\", \"\"),\r\n  71:         \"forbidden_plot_patterns\": list(profile.get(\"forbidden_plot_patterns\", [])),\r\n  72:         \"outline_system_prompt\": profile.get(\"outline_system_prompt\") or \"\",\r\n  73:     }\r\n  74: \r\n  75: \r\n  76: def style_picker_overrides(profile: dict[str, Any]) -> dict[str, str]:\r\n  77:     \"\"\"Kwargs for _otr_style_picker.pick_style (locked signature). Empty\r\n  78:     string preserves the science/module constants; the science profile leaves\r\n  79:     these unset so its behavior is byte-identical.\"\"\"\r\n  80: \r\n  81:     profile = validate_profile(profile)\r\n  82:     return {\r\n  83:         \"inventor_system_prompt\": profile.get(\"style_picker_inventor_system_prompt\") or \"\",\r\n  84:         \"chooser_system_prompt\": profile.get(\"style_picker_chooser_system_prompt\") or \"\",\r\n  85:         \"chooser_user_template\": profile.get(\"style_picker_chooser_user_template\") or \"\",\r\n  86:     }\r\n  87: \r\n  88: \r\n  89: def coda_mode(profile: dict[str, Any]) -> str:\r\n  90:     return validate_profile(profile)[\"coda_mode\"]\r\n  91: \r\n  92: \r\n  93: def line_grounding_instruction(profile: dict[str, Any]) -> str:\r\n  94:     return validate_profile(profile)[\"line_grounding_instruction\"]\r\n  95: \r\n  96: \r\n  97: def dramatic_state_labels(profile: dict[str, Any]) -> dict[str, str]:\r\n  98:     \"\"\"Labels for _otr_dramatic_state_llm (replaces hardcoded NEWS KEY TERMS /\r\n  99:     NEWS PREMISE for non-science lanes).\"\"\"\r\n 100: \r\n 101:     profile = validate_profile(profile)\r\n 102:     return {\r\n 103:         \"key_terms_label\": profile.get(\"key_terms_label\", \"KEY TERMS\"),\r\n 104:         \"premise_label\": f\"{profile['source_material_label'].upper()} PREMISE\",\r\n 105:         \"grounding_label\": profile[\"source_grounding_label\"],\r\n 106:     }\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'production_mirror\\\\nodes\\\\OTR_LedgerScriptWriter.py' | Select-Object -Skip 1180 -First 230 | ForEach-Object { \"'$global:i = $global:i + 1; '\"'{0,4}: {1}' -f (\"'$global:i+1180), $_ }'","aggregated_output":"1181:         if not seed_text:\r\n1182:             raise RuntimeError(\"fetched article had empty headline/summary/full_text\")\r\n1183:         log.info(\r\n1184:             \"[OTR_LedgerScriptWriter] RSS_FETCH OK: source=%s, len=%d, head=%r\",\r\n1185:             article.get(\"source\") or \"?\", len(seed_text), seed_text[:80],\r\n1186:         )\r\n1187:         return {\r\n1188:             \"headline\":  (article.get(\"headline\") or \"\").strip(),\r\n1189:             \"summary\":   (article.get(\"summary\") or \"\").strip(),\r\n1190:             \"full_text\": (article.get(\"full_text\") or \"\").strip(),\r\n1191:             \"source\":    (article.get(\"source\") or \"\").strip(),\r\n1192:             \"date\":      (article.get(\"date\") or \"\").strip(),\r\n1193:             \"link\":      (article.get(\"link\") or \"\").strip(),\r\n1194:             \"seed_text\": seed_text,\r\n1195:         }\r\n1196:     except Exception as exc:\r\n1197:         # Loud raise: the writer requires a real seed to function. The\r\n1198:         # workflow can override via custom_premise if RSS is unavailable.\r\n1199:         raise RuntimeError(\r\n1200:             f\"[OTR_LedgerScriptWriter] RSS fetch failed: {exc}. \"\r\n1201:             f\"Type a non-empty value into the `custom_premise` widget to \"\r\n1202:             f\"bypass the RSS pipeline.\",\r\n1203:         ) from exc\r\n1204: \r\n1205: \r\n1206: def _resolve_inputs(\r\n1207:     episode_title: str = \"\",\r\n1208:     target_words: int = 350,\r\n1209:     num_characters: int = 2,\r\n1210:     *,\r\n1211:     # S30 B2a: split single model_id input into the two writer-surface\r\n1212:     # slots. Labels passed in may carry the [NOT DOWNLOADED] suffix from\r\n1213:     # the dropdown; _strip_label_suffix normalizes both before they hit\r\n1214:     # the meta block or any consumer.\r\n1215:     creative_writing_model: str = _otr_model_catalog.DEFAULT_LLM,\r\n1216:     technical_model: str = _otr_model_catalog.DEFAULT_LLM,\r\n1217:     custom_premise: str = \"\",\r\n1218:     include_act_breaks: bool = True,\r\n1219:     act_count: str = \"auto\",\r\n1220:     style: str = _STYLE_AUTO_SENTINEL,\r\n1221:     style_custom: str = \"\",\r\n1222:     creativity: str = \"balanced\",\r\n1223:     optimization_profile: str = \"Standard\",\r\n1224:     perfect_run_spacesaver: bool = False,\r\n1225:     # Phase 4 v4 (2026-05-11) sampling knobs. Tier 2 fix #17\r\n1226:     # defaults flipped to 0.05 / 1.03 (validated improvement over\r\n1227:     # disabled baseline on the small-LLM class).\r\n1228:     min_p: float = 0.05,\r\n1229:     repetition_penalty: float = 1.03,\r\n1230:     max_new_tokens_cap: int = 200,\r\n1231:     # Sprint 10B Wave 1 Agent B: Stage 3 validators flag.\r\n1232:     enable_production_stage3_validators: bool = False,\r\n1233:     # Sprint 2.2 (2026-05-28): when True, news_interpreter exhaustion\r\n1234:     # halts the run rather than graceful-degrading to meta[\"news\"]=None.\r\n1235:     news_briefs_required: bool = True,\r\n1236:     # Build 4 (2026-05-28): grouped-exchange dialogue path. When True the\r\n1237:     # render loop pre-passes voiced beat groups through compose_exchange.\r\n1238:     use_exchange: bool = False,\r\n1239:     # OpenRouter 4-dropdown router (2026-06-01, S2): the two slot-slug\r\n1240:     # pickers. PASSIVE bindings -- threaded into the resolved dict here and\r\n1241:     # consumed by slot resolution in S3. Default \"\" so an old workflow with\r\n1242:     # no slot widgets resolves them as unset -> the S3 fallback chain.\r\n1243:     openrouter_slot_a_model: str = \"\",\r\n1244:     openrouter_slot_b_model: str = \"\",\r\n1245:     comfy_slot_a_model: str = \"\",\r\n1246:     comfy_slot_b_model: str = \"\",\r\n1247: ) -> dict:\r\n1248:     \"\"\"Resolve raw widget values into the effective set used by the run.\r\n1249: \r\n1250:     Returns a single dict. Logs at INFO for branches that override the\r\n1251:     widget value (RSS fetch, smoke preset, style_custom override).\r\n1252: \r\n1253:     Both story and style follow the same dual-axis pattern (per Jeffrey\r\n1254:     2026-05-10 \"there is the story, and the style ƒ?\" those two drive\r\n1255:     story content so we need both\"):\r\n1256: \r\n1257:       - story:   custom_premise verbatim > RSS auto-fetch.\r\n1258:       - style:   style_custom verbatim > `style` combo verbatim, EXCEPT\r\n1259:                  when combo == `_STYLE_AUTO_SENTINEL`, in which case\r\n1260:                  the writer defers to ``_generate_style_via_llm``\r\n1261:                  once the model is loaded. This helper returns\r\n1262:                  ``style_pending=True`` on the dict in that case so\r\n1263:                  the caller knows to call the LLM.\r\n1264: \r\n1265:     Resolution order for the final style string:\r\n1266:       1. style_custom (free-text, takes precedence)\r\n1267:       2. style combo verbatim if != _STYLE_AUTO_SENTINEL\r\n1268:       3. LLM-generated (caller fills `resolved[\"style\"]` post-load)\r\n1269:     \"\"\"\r\n1270:     # S30 B2a: normalize each model id by stripping the [NOT DOWNLOADED]\r\n1271:     # dropdown suffix. Raw widget values never reach a consumer / meta\r\n1272:     # stamp -- catalog._strip_label_suffix is the single normalization\r\n1273:     # point. Default both inputs to _otr_model_catalog.DEFAULT_LLM so an empty widget\r\n1274:     # value (e.g. an old workflow with shorter widgets_values vector)\r\n1275:     # still produces a usable id.\r\n1276:     creative_writing_model = _otr_model_catalog._strip_label_suffix(\r\n1277:         str(creative_writing_model or _otr_model_catalog.DEFAULT_LLM)\r\n1278:     )\r\n1279:     technical_model = _otr_model_catalog._strip_label_suffix(\r\n1280:         str(technical_model or _otr_model_catalog.DEFAULT_LLM)\r\n1281:     )\r\n1282: \r\n1283:     target_words = _resolve_target_words(target_words)\r\n1284:     num_characters = max(1, min(6, int(num_characters)))\r\n1285: \r\n1286:     # Phase 2A: act_count resolution. The widget is a combo --\r\n1287:     # \"auto\" (the default) means auto-derive via\r\n1288:     # _otr_episode_budget.auto_act_count, which scales the act count up\r\n1289:     # with target_words (fewest acts whose widened-beat budget fits the\r\n1290:     # length); \"1\"..\"7\" set it explicitly. An explicit pick is validated\r\n1291:     # against the [default..max] band by compute_episode_budget in run().\r\n1292:     _act_count_raw = str(act_count).strip().lower()\r\n1293:     if _act_count_raw in (\"\", \"auto\"):\r\n1294:         act_count_int = 0\r\n1295:     else:\r\n1296:         try:\r\n1297:             act_count_int = max(1, min(7, int(_act_count_raw)))\r\n1298:         except (TypeError, ValueError):\r\n1299:             act_count_int = 0\r\n1300:     if act_count_int == 0:\r\n1301:         try:\r\n1302:             from . import _otr_episode_budget as _OTRB  # type: ignore\r\n1303:             act_count_int = _OTRB.auto_act_count(target_words)\r\n1304:         except Exception as exc:  # noqa: BLE001\r\n1305:             # If target_words is below 30, auto_act_count raises (via\r\n1306:             # default_act_count); fall through to act_count=1 and let\r\n1307:             # compute_episode_budget surface the structured\r\n1308:             # InvalidEpisodeBudgetError in run().\r\n1309:             log.warning(\r\n1310:                 \"[OTR_LedgerScriptWriter] act_count auto-derive failed \"\r\n1311:                 \"(target_words=%d): %s -- defaulting to 1\",\r\n1312:                 target_words, exc,\r\n1313:             )\r\n1314:             act_count_int = 1\r\n1315:     temperature, top_p = _resolve_creativity(creativity)\r\n1316:     custom = (custom_premise or \"\").strip()\r\n1317: \r\n1318:     sc = (style_custom or \"\").strip()\r\n1319:     style_combo = (style or \"\").strip()\r\n1320:     if sc:\r\n1321:         resolved_style = sc\r\n1322:         style_source = \"style_custom\"\r\n1323:         style_pending = False\r\n1324:     elif style_combo and style_combo != _STYLE_AUTO_SENTINEL:\r\n1325:         resolved_style = style_combo\r\n1326:         style_source = \"style_combo\"\r\n1327:         style_pending = False\r\n1328:     else:\r\n1329:         # auto / empty -> defer to LLM post-load.\r\n1330:         resolved_style = \"\"        # caller fills\r\n1331:         style_source = \"llm_auto\"\r\n1332:         style_pending = True\r\n1333: \r\n1334:     if custom:\r\n1335:         # Custom premise path: synthesize the same dict shape RSS\r\n1336:         # would produce so news_interpreter sees a uniform article\r\n1337:         # surface no matter how the story entered the writer.\r\n1338:         news_article = {\r\n1339:             \"headline\":  \"\",\r\n1340:             \"summary\":   \"\",\r\n1341:             \"full_text\": custom,\r\n1342:             \"source\":    \"User Seed\",\r\n1343:             \"date\":      \"\",\r\n1344:             \"link\":      \"\",\r\n1345:             \"seed_text\": custom,\r\n1346:         }\r\n1347:         news_seed = custom\r\n1348:         seed_source = \"custom_premise\"\r\n1349:     else:\r\n1350:         # Best-effort RSS re-rank slug. If style is still pending\r\n1351:         # (auto/LLM), use the hardcoded fallback only for the slug --\r\n1352:         # the writer's final style still gets LLM-proposed from the\r\n1353:         # ACTUAL fetched article below.\r\n1354:         rss_style_slug = resolved_style or _LLM_STYLE_FALLBACK\r\n1355:         # S31 B6 Fix 1: pass `technical_model`. Post-S31 B3, the RSS\r\n1356:         # rerank path inside `_fetch_rss_seed_or_die` routes through\r\n1357:         # `_otr_model_loader.request_slot(\"technical\", model_id)` (both\r\n1358:         # call sites: `_llm_rank_news_candidates` headline rank and\r\n1359:         # `_llm_rerank_with_bodies` body rerank). Passing\r\n1360:         # `creative_writing_model` here would make the slot label\r\n1361:         # (\"technical\") and the resolved id (creative model) disagree\r\n1362:         # in differing-slots mode -- the slot scheduler would load the\r\n1363:         # creative model under the technical slot label, defeating the\r\n1364:         # whole point of two-slot routing. In default config (creative\r\n1365:         # == technical) the two ids are identical so the fix is a\r\n1366:         # no-op at runtime; in differing-slots config (S32 forward)\r\n1367:         # this is load-bearing.\r\n1368:         news_article = _fetch_rss_seed_or_die(\r\n1369:             rss_style_slug, technical_model,\r\n1370:         )\r\n1371:         news_seed = news_article[\"seed_text\"]\r\n1372:         seed_source = \"rss_fetch\"\r\n1373: \r\n1374:     return {\r\n1375:         \"news_seed\":            news_seed,\r\n1376:         \"news_article\":         news_article,\r\n1377:         \"seed_source\":          seed_source,\r\n1378:         \"style\":                resolved_style,\r\n1379:         \"style_source\":         style_source,\r\n1380:         \"style_pending\":        style_pending,\r\n1381:         \"style_combo\":          style_combo,\r\n1382:         \"style_custom\":         sc,\r\n1383:         \"target_words\":         target_words,\r\n1384:         \"num_characters\":       num_characters,\r\n1385:         \"episode_title\":        (episode_title or \"\").strip(),\r\n1386:         # S30 B2b: per-slot keys ONLY. The legacy `model_id` key is\r\n1387:         # deleted outright; consumers route via creative_writing_model\r\n1388:         # / technical_model. No \"stamp both\" hedge.\r\n1389:         \"creative_writing_model\": creative_writing_model,\r\n1390:         \"technical_model\":        technical_model,\r\n1391:         \"include_act_breaks\":   bool(include_act_breaks),\r\n1392:         \"act_count\":            int(act_count_int),\r\n1393:         \"creativity\":           str(creativity),\r\n1394:         \"temperature\":          float(temperature),\r\n1395:         \"top_p\":                float(top_p),\r\n1396:         \"optimization_profile\": str(optimization_profile),\r\n1397:         \"perfect_run_spacesaver\": bool(perfect_run_spacesaver),\r\n1398:         # Phase 4 v4 (2026-05-11) sampling knobs. Clamped to widget\r\n1399:         # ranges so a hand-edited workflow JSON can't slip through\r\n1400:         # out-of-band values.\r\n1401:         \"min_p\":                max(0.0, min(0.5, float(min_p or 0.0))),\r\n1402:         \"repetition_penalty\":   max(1.0, min(1.2, float(\r\n1403:             repetition_penalty or 1.0,\r\n1404:         ))),\r\n1405:         \"max_new_tokens_cap\":   max(40, min(400, int(\r\n1406:             max_new_tokens_cap or 200,\r\n1407:         ))),\r\n1408:         # Sprint 10B Wave 1 Agent B Stage 3 validators flag.\r\n1409:         \"enable_production_stage3_validators\":\r\n1410:             bool(enable_production_stage3_validators),\r\n","exit_code":0,"status":"completed"}}
