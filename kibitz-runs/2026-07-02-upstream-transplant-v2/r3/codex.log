"date\", \"link\", \"seed_text\",\r\n  31: )\r\n  32: REQUIRED_TOP_LEVEL = (\r\n  33:     \"schema_version\", \"created_utc\", \"ledger_writing_spec\", \"meta_mirrors\",\r\n  34:     \"adapter_news_article\",\r\n  35: )\r\n  36: REQUIRED_SPEC_IDS = (\r\n  37:     \"source_bank_id\", \"story_model_id\", \"story_pipeline_id\", \"visual_style_id\",\r\n  38: )\r\n  39: SUPPORTED_SCHEMA_VERSIONS = (\"v2.0\",)\r\n  40: \r\n  41: \r\n  42: class BridgeInputError(ValueError):\r\n  43:     \"\"\"The bridge artifact is unusable. Message says exactly why. There is no\r\n  44:     partial acceptance and no fallback payload.\"\"\"\r\n  45: \r\n  46: \r\n  47: def _require(condition: bool, message: str) -> None:\r\n  48:     if not condition:\r\n  49:         raise BridgeInputError(message)\r\n  50: \r\n  51: \r\n  52: def validate_bridge_artifact(\r\n  53:     data: dict[str, Any],\r\n  54:     *,\r\n  55:     news_briefs_model: Callable[..., Any] | None = None,\r\n  56: ) -> dict[str, Any]:\r\n  57:     \"\"\"Validate and return the artifact dict; raise BridgeInputError on any\r\n  58:     defect. `news_briefs_model` is the production NewsBriefs class when\r\n  59:     called from production code (strongest validation path).\"\"\"\r\n  60: \r\n  61:     _require(isinstance(data, dict), \"bridge artifact must be a JSON object\")\r\n  62:     missing = [k for k in REQUIRED_TOP_LEVEL if k not in data]\r\n  63:     _require(not missing, f\"bridge artifact missing top-level keys: {missing}\")\r\n  64:     _require(\r\n  65:         data[\"schema_version\"] in SUPPORTED_SCHEMA_VERSIONS,\r\n  66:         f\"unsupported bridge schema_version {data['schema_version']!r}; \"\r\n  67:         f\"supported: {SUPPORTED_SCHEMA_VERSIONS}\",\r\n  68:     )\r\n  69: \r\n  70:     spec = data[\"ledger_writing_spec\"]\r\n  71:     _require(isinstance(spec, dict), \"ledger_writing_spec must be an object\")\r\n  72:     for key in REQUIRED_SPEC_IDS:\r\n  73:         _require(\r\n  74:             bool(str(spec.get(key, \"\")).strip()),\r\n  75:             f\"ledger_writing_spec.{key} is required and empty\",\r\n  76:         )\r\n  77:     profile = spec.get(\"prompt_profile\")\r\n  78:     _require(isinstance(profile, dict), \"ledger_writing_spec.prompt_profile missing\")\r\n  79:     for key in (\"source_bank_id\", \"story_model_id\"):\r\n  80:         _require(\r\n  81:             profile.get(key) == spec.get(key),\r\n  82:             f\"prompt_profile.{key} != spec.{key} - refusing inconsistent spec\",\r\n  83:         )\r\n  84:     policy = spec.get(\"visual_policy\")\r\n  85:     _require(isinstance(policy, dict), \"ledger_writing_spec.visual_policy missing\")\r\n  86:     _require(\r\n  87:         policy.get(\"style_id\") == spec.get(\"visual_style_id\"),\r\n  88:         \"visual_policy.style_id != spec.visual_style_id\",\r\n  89:     )\r\n  90: \r\n  91:     mirrors = data[\"meta_mirrors\"]\r\n  92:     _require(isinstance(mirrors, dict), \"meta_mirrors must be an object\")\r\n  93:     news = mirrors.get(\"news\")\r\n  94:     _require(isinstance(news, dict), \"meta_mirrors.news missing\")\r\n  95:     if news_briefs_model is not None:\r\n  96:         try:\r\n  97:             news_briefs_model(**news)\r\n  98:         except Exception as exc:\r\n  99:             raise BridgeInputError(\r\n 100:                 f\"meta_mirrors.news failed NewsBriefs validation: {exc}\"\r\n 101:             ) from exc\r\n 102:     else:\r\n 103:         _require(\r\n 104:             set(news) == set(NEWS_BRIEFS_FIELDS),\r\n 105:             \"meta_mirrors.news keys != NewsBriefs fields: \"\r\n 106:             f\"{sorted(set(news) ^ set(NEWS_BRIEFS_FIELDS))}\",\r\n 107:         )\r\n 108:     _require(isinstance(news.get(\"key_terms\"), list),\r\n 109:              \"meta_mirrors.news.key_terms must be a list (freeze invariant)\")\r\n 110: \r\n 111:     seed = mirrors.get(\"news_seed\")\r\n 112:     _require(isinstance(seed, dict), \"meta_mirrors.news_seed missing\")\r\n 113:     _require(\r\n 114:         set(seed) == set(NEWS_SEED_KEYS),\r\n 115:         f\"meta_mirrors.news_seed keys drifted: {sorted(set(seed) ^ set(NEWS_SEED_KEYS))}\",\r\n 116:     )\r\n 117:     _require(bool(str(seed.get(\"headline\", \"\")).strip()),\r\n 118:              \"meta_mirrors.news_seed.headline is required (consumer-read key)\")\r\n 119: \r\n 120:     article = data[\"adapter_news_article\"]\r\n 121:     _require(isinstance(article, dict), \"adapter_news_article must be an object\")\r\n 122:     _require(\r\n 123:         set(article) == set(NEWS_ARTICLE_KEYS),\r\n 124:         f\"adapter_news_article keys drifted: {sorted(set(article) ^ set(NEWS_ARTICLE_KEYS))}\",\r\n 125:     )\r\n 126:     _require(bool(str(article.get(\"seed_text\", \"\")).strip()),\r\n 127:              \"adapter_news_article.seed_text is required and empty\")\r\n 128:     return data\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'transplant_work\\\\production_new_modules\\\\_otr_source_interpreter.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Source interpreter facade for the OTR upstream transplant.\r\n   2: \r\n   3: DESTINATION: ComfyUI-OldTimeRadio/nodes/_otr_source_interpreter.py\r\n   4: STATUS: staged in the lab (transplant_work/); NOT installed yet.\r\n   5: \r\n   6: Declared contract (kibitz r1/r2):\r\n   7: \r\n   8:     interpret_source(bank_id, *, article=None, bridge_story_input=None,\r\n   9:                      news_briefs_builder=None, **builder_kwargs)\r\n  10:         -> {\"casting_brief\", \"script_brief\", \"close_brief\", \"key_terms\"}\r\n  11: \r\n  12: - science_news REQUIRES news_briefs_builder (production wires\r\n  13:   news_interpreter.build_news_briefs verbatim; this facade never re-implements\r\n  14:   the science brain and adds no science prose).\r\n  15: - media_archive / public_domain_story are PACKET-DRIVEN in v1: they REQUIRE\r\n  16:   bridge_story_input (the validated bridge artifact's story_input block).\r\n  17:   Live archive fetching is a later declared binding, not v1.\r\n  18: - Anything else: loud error. No lane ever borrows another lane's brain.\r\n  19: \"\"\"\r\n  20: \r\n  21: from __future__ import annotations\r\n  22: \r\n  23: from typing import Any, Callable\r\n  24: \r\n  25: PACKET_DRIVEN_BANKS = (\"media_archive\", \"public_domain_story\")\r\n  26: LOGICAL_FIELDS = (\"casting_brief\", \"script_brief\", \"close_brief\", \"key_terms\")\r\n  27: \r\n  28: \r\n  29: class SourceInterpreterError(ValueError):\r\n  30:     \"\"\"No usable source brain for this bank/input combination.\"\"\"\r\n  31: \r\n  32: \r\n  33: def _from_bridge_story_input(bank_id: str, story_input: dict[str, Any]) -> dict[str, Any]:\r\n  34:     if not isinstance(story_input, dict):\r\n  35:         raise SourceInterpreterError(\r\n  36:             f\"{bank_id}: bridge_story_input must be an object\"\r\n  37:         )\r\n  38:     if story_input.get(\"source_bank_id\") != bank_id:\r\n  39:         raise SourceInterpreterError(\r\n  40:             f\"bridge story_input bank {story_input.get('source_bank_id')!r} \"\r\n  41:             f\"!= requested bank {bank_id!r} - refusing cross-lane input\"\r\n  42:         )\r\n  43:     out: dict[str, Any] = {}\r\n  44:     for field in LOGICAL_FIELDS:\r\n  45:         value = story_input.get(field)\r\n  46:         if field == \"key_terms\":\r\n  47:             if not isinstance(value, list):\r\n  48:                 raise SourceInterpreterError(\r\n  49:                     f\"{bank_id}: story_input.key_terms must be a list\"\r\n  50:                 )\r\n  51:             out[field] = list(value)\r\n  52:         else:\r\n  53:             if not str(value or \"\").strip():\r\n  54:                 raise SourceInterpreterError(\r\n  55:                     f\"{bank_id}: story_input.{field} is required and empty \"\r\n  56:                     \"(the lab authors this content in JSON; nothing is invented here)\"\r\n  57:                 )\r\n  58:             out[field] = str(value)\r\n  59:     return out\r\n  60: \r\n  61: \r\n  62: def interpret_source(\r\n  63:     bank_id: str,\r\n  64:     *,\r\n  65:     article: dict[str, Any] | None = None,\r\n  66:     bridge_story_input: dict[str, Any] | None = None,\r\n  67:     news_briefs_builder: Callable[..., Any] | None = None,\r\n  68:     **builder_kwargs: Any,\r\n  69: ) -> dict[str, Any]:\r\n  70:     bank = (bank_id or \"\").strip()\r\n  71:     if bank == \"science_news\":\r\n  72:         if news_briefs_builder is None:\r\n  73:             raise SourceInterpreterError(\r\n  74:                 \"science_news requires news_briefs_builder \"\r\n  75:                 \"(wire news_interpreter.build_news_briefs); the facade never \"\r\n  76:                 \"re-implements the science brain\"\r\n  77:             )\r\n  78:         briefs = news_briefs_builder(article=article, **builder_kwargs)\r\n  79:         data = briefs.model_dump() if hasattr(briefs, \"model_dump\") else dict(briefs)\r\n  80:         return {\r\n  81:             \"casting_brief\": data[\"casting_brief\"],\r\n  82:             \"script_brief\": data[\"script_brief\"],\r\n  83:             \"close_brief\": data[\"news_close_brief\"],\r\n  84:             \"key_terms\": list(data[\"key_terms\"]),\r\n  85:         }\r\n  86:     if bank in PACKET_DRIVEN_BANKS:\r\n  87:         if bridge_story_input is None:\r\n  88:             raise SourceInterpreterError(\r\n  89:                 f\"{bank} is packet-driven in v1 and requires bridge_story_input \"\r\n  90:                 \"(a validated bridge artifact's story_input block); there is no \"\r\n  91:                 \"live fetcher for this lane yet and no fallback to science RSS\"\r\n  92:             )\r\n  93:         return _from_bridge_story_input(bank, bridge_story_input)\r\n  94:     if bank == \"custom_source_bank\":\r\n  95:         raise SourceInterpreterError(\r\n  96:             \"custom_source_bank is visible but not runnable: create and \"\r\n  97:             \"validate a custom schema, source packet, and story pack first \"\r\n  98:             \"(see upstream lab CUSTOM_SOURCE_BANK_GUIDE.md)\"\r\n  99:         )\r\n 100:     raise SourceInterpreterError(f\"unknown source bank {bank!r}\")\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'nodes.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Live ComfyUI nodes for the OTR upstream story lab v2 (transplant workspace).\r\n   2: \r\n   3: Every dropdown choice is REGISTRY-DISCOVERED from fixtures JSON - no\r\n   4: module-level content lists (kibitz r1). Unknown/unrunnable selections raise;\r\n   5: there are no hidden compatibility fallbacks. This package is not imported by\r\n   6: production and does not touch the production workflow.\r\n   7: \"\"\"\r\n   8: \r\n   9: from __future__ import annotations\r\n  10: \r\n  11: import hashlib\r\n  12: import json\r\n  13: import sys\r\n  14: from pathlib import Path\r\n  15: from typing import Any\r\n  16: \r\n  17: LAB_ROOT = Path(__file__).resolve().parent\r\n  18: LAB_SRC = LAB_ROOT / \"src\"\r\n  19: \r\n  20: \r\n  21: def _ensure_lab_importable() -> None:\r\n  22:     if not LAB_SRC.exists():\r\n  23:         raise RuntimeError(f\"Upstream Story Lab source folder missing: {LAB_SRC}\")\r\n  24:     lab_src = str(LAB_SRC)\r\n  25:     if lab_src not in sys.path:\r\n  26:         sys.path.insert(0, lab_src)\r\n  27: \r\n  28: \r\n  29: def _registry():\r\n  30:     _ensure_lab_importable()\r\n  31:     from upstream_story_lab.registry import Registry\r\n  32: \r\n  33:     return Registry(LAB_ROOT)\r\n  34: \r\n  35: \r\n  36: def _lab_state_digest() -> str:\r\n  37:     digest = hashlib.sha256()\r\n  38:     paths = [LAB_ROOT / \"__init__.py\", LAB_ROOT / \"nodes.py\"]\r\n  39:     for folder in (LAB_SRC, LAB_ROOT / \"fixtures\"):\r\n  40:         if folder.exists():\r\n  41:             paths.extend(\r\n  42:                 p for p in folder.rglob(\"*\")\r\n  43:                 if p.is_file() and \"__pycache__\" not in p.parts and p.suffix != \".pyc\"\r\n  44:             )\r\n  45:     for path in sorted(paths):\r\n  46:         try:\r\n  47:             stat = path.stat()\r\n  48:             digest.update(path.relative_to(LAB_ROOT).as_posix().encode(\"utf-8\"))\r\n  49:             digest.update(str(stat.st_size).encode(\"utf-8\"))\r\n  50:             digest.update(str(stat.st_mtime_ns).encode(\"utf-8\"))\r\n  51:         except OSError as exc:\r\n  52:             digest.update(f\"{path}:ERROR:{exc}\".encode(\"utf-8\"))\r\n  53:     return digest.hexdigest()\r\n  54: \r\n  55: \r\n  56: def _bank_choices() -> list[str]:\r\n  57:     return sorted(_registry().banks)\r\n  58: \r\n  59: \r\n  60: def _model_choices() -> list[str]:\r\n  61:     registry = _registry()\r\n  62:     models = {\r\n  63:         model_id\r\n  64:         for (_bank, model_id, _pipe), (pack, _p) in registry.packs.items()\r\n  65:         if pack.status != \"experimental\"\r\n  66:     }\r\n  67:     return sorted(models) + [\"auto\"]\r\n  68: \r\n  69: \r\n  70: def _pipeline_choices() -> list[str]:\r\n  71:     return sorted(_registry().pipelines) + [\"auto\"]\r\n  72: \r\n  73: \r\n  74: def _style_choices() -> list[str]:\r\n  75:     return sorted(_registry().styles) + [\"auto\"]\r\n  76: \r\n  77: \r\n  78: class OTR_UpstreamStoryLabValidator:\r\n  79:     \"\"\"Run the registry + matrix + leakage + drift checks and report.\"\"\"\r\n  80: \r\n  81:     CATEGORY = \"OTR/Upstream Story Lab\"\r\n  82:     RETURN_TYPES = (\"STRING\",)\r\n  83:     RETURN_NAMES = (\"report\",)\r\n  84:     FUNCTION = \"validate\"\r\n  85: \r\n  86:     @classmethod\r\n  87:     def INPUT_TYPES(cls) -> dict[str, dict[str, Any]]:\r\n  88:         return {\"required\": {}}\r\n  89: \r\n  90:     @classmethod\r\n  91:     def IS_CHANGED(cls, **kwargs: Any) -> str:\r\n  92:         return _lab_state_digest()\r\n  93: \r\n  94:     def validate(self) -> tuple[str]:\r\n  95:         _ensure_lab_importable()\r\n  96:         from upstream_story_lab.bridge import build_spec\r\n  97:         from upstream_story_lab.compat import (\r\n  98:             MOTION_ROLE_KEYS,\r\n  99:             NEWS_BRIEFS_FIELDS,\r\n 100:             PRODUCTION_VISUAL_TAILS,\r\n 101:             extract_motion_role_keys,\r\n 102:             extract_news_briefs_fields,\r\n 103:             extract_visual_tails,\r\n 104:         )\r\n 105:         from upstream_story_lab.preview import (\r\n 106:             render_prompt_preview,\r\n 107:             scan_story_leakage,\r\n 108:             scan_visual_leakage,\r\n 109:         )\r\n 110: \r\n 111:         registry = _registry()\r\n 112:         mirror = LAB_ROOT / \"production_mirror\" / \"nodes\"\r\n 113: \r\n 114:         drift: list[str] = []\r\n 115:         if tuple(extract_news_briefs_fields(mirror / \"news_interpreter.py\")) != NEWS_BRIEFS_FIELDS:\r\n 116:             drift.append(\"NewsBriefs fields drifted\")\r\n 117:         if tuple(extract_motion_role_keys(\r\n 118:             mirror / \"_otr_video_engines\" / \"render_driver.py\"\r\n 119:         )) != MOTION_ROLE_KEYS:\r\n 120:             drift.append(\"motion role keys drifted\")\r\n 121:         if extract_visual_tails(mirror / \"_otr_story_brief_helpers.py\") != PRODUCTION_VISUAL_TAILS:\r\n 122:             drift.append(\"visual tail constants drifted\")\r\n 123:         if drift:\r\n 124:             raise RuntimeError(\r\n 125:                 \"Production mirror drift detected: \" + \"; \".join(drift)\r\n 126:                 + \" - re-verify and re-pin compat.py before transplant work.\"\r\n 127:             )\r\n 128: \r\n 129:         leaks: list[str] = []\r\n 130:         combos = 0\r\n 131:         for (bank_id, model_id, pipeline_id), (pack, _p) in registry.packs.items():\r\n 132:             if bank_id == \"custom_source_bank\":\r\n 133:                 continue\r\n 134:             spec = build_spec(\r\n 135:                 registry, source_bank_id=bank_id, story_model_id=model_id,\r\n 136:                 story_pipeline_id=pipeline_id,\r\n 137:             )\r\n 138:             combos += 1\r\n 139:             if bank_id != \"science_news\":\r\n 140:                 found = scan_story_leakage(registry, spec)\r\n 141:                 if found:\r\n 142:                     leaks.append(f\"{bank_id}/{model_id}: {found}\")\r\n 143:             visual_found = scan_visual_leakage(spec)\r\n 144:             if visual_found:\r\n 145:                 leaks.append(f\"{bank_id}/{model_id} visual: {visual_found}\")\r\n 146:             assert render_prompt_preview(spec)\r\n 147:         if leaks:\r\n 148:             raise RuntimeError(f\"Leakage detected: {leaks}\")\r\n 149: \r\n 150:         manifests = registry.public_domain_manifests()\r\n 151:         lines = [\r\n 152:             \"OK Upstream Story Lab v2 (transplant workspace)\",\r\n 153:             f\"lab_root={LAB_ROOT}\",\r\n 154:             f\"banks={sorted(registry.banks)}\",\r\n 155:             f\"story_packs={len(registry.packs)}\",\r\n 156:             f\"visual_styles={sorted(registry.styles)}\",\r\n 157:             f\"pipelines={sorted(registry.pipelines)}\",\r\n 158:             f\"validated_specs={combos}\",\r\n 159:             f\"public_domain_manifests={len(manifests)}\",\r\n 160:             \"mirror_drift=none\",\r\n 161:             \"production_workflow=not touched by this lab node\",\r\n 162:         ]\r\n 163:         return (\"\\n\".join(lines),)\r\n 164: \r\n 165: \r\n 166: class OTR_StoryPackPreview:\r\n 167:     \"\"\"Preview one explicit selection; every choice is registry-discovered.\"\"\"\r\n 168: \r\n 169:     CATEGORY = \"OTR/Upstream Story Lab\"\r\n 170:     RETURN_TYPES = (\"STRING\",)\r\n 171:     RETURN_NAMES = (\"preview_json\",)\r\n 172:     FUNCTION = \"preview\"\r\n 173: \r\n 174:     @classmethod\r\n 175:     def INPUT_TYPES(cls) -> dict[str, dict[str, Any]]:\r\n 176:         return {\r\n 177:             \"required\": {\r\n 178:                 \"source_bank_id\": (_bank_choices(), {\"default\": \"media_archive\"}),\r\n 179:                 \"story_model_id\": (_model_choices(), {\"default\": \"auto\"}),\r\n 180:                 \"story_pipeline_id\": (_pipeline_choices(), {\"default\": \"auto\"}),\r\n 181:                 \"visual_style_id\": (_style_choices(), {\"default\": \"auto\"}),\r\n 182:             },\r\n 183:         }\r\n 184: \r\n 185:     @classmethod\r\n 186:     def IS_CHANGED(cls, **kwargs: Any) -> str:\r\n 187:         return _lab_state_digest()\r\n 188: \r\n 189:     def preview(self, source_bank_id: str, story_model_id: str,\r\n 190:                 story_pipeline_id: str, visual_style_id: str) -> tuple[str]:\r\n 191:         _ensure_lab_importable()\r\n 192:         from upstream_story_lab.bridge import build_bridge_artifact, build_spec\r\n 193:         from upstream_story_lab.preview import (\r\n 194:             render_prompt_preview,\r\n 195:             render_visual_preview,\r\n 196:         )\r\n 197: \r\n 198:         registry = _registry()\r\n 199:         spec = build_spec(\r\n 200:             registry,\r\n 201:             source_bank_id=source_bank_id,\r\n 202:             story_model_id=story_model_id,\r\n 203:             story_pipeline_id=story_pipeline_id,\r\n 204:             visual_style_id=visual_style_id,\r\n 205:         )\r\n 206:         artifact = build_bridge_artifact(spec)\r\n 207:         result = {\r\n 208:             \"status\": \"ok\",\r\n 209:             \"lab_root\": str(LAB_ROOT),\r\n 210:             \"resolution\": spec.resolution.model_dump(mode=\"json\"),\r\n 211:             \"provenance\": spec.provenance.model_dump(mode=\"json\"),\r\n 212:             \"prompt_preview\": render_prompt_preview(spec),\r\n 213:             \"visual_preview\": render_visual_preview(spec),\r\n 214:             \"bridge_artifact\": artifact.model_dump(mode=\"json\"),\r\n 215:             \"notes\": [\r\n 216:                 \"Live upstream lab preview only; the production workflow is untouched.\",\r\n 217:                 \"Invalid source/story/style/pipeline combinations fail loudly.\",\r\n 218:             ],\r\n 219:         }\r\n 220:         return (json.dumps(result, indent=2, ensure_ascii=False),)\r\n 221: \r\n 222: \r\n 223: class OTR_BridgeArtifactEmit:\r\n 224:     \"\"\"Explicitly write the frozen bridge artifact JSON to bridge_out/.\"\"\"\r\n 225: \r\n 226:     CATEGORY = \"OTR/Upstream Story Lab\"\r\n 227:     RETURN_TYPES = (\"STRING\",)\r\n 228:     RETURN_NAMES = (\"artifact_path\",)\r\n 229:     FUNCTION = \"emit\"\r\n 230:     OUTPUT_NODE = True\r\n 231: \r\n 232:     @classmethod\r\n 233:     def INPUT_TYPES(cls) -> dict[str, dict[str, Any]]:\r\n 234:         return {\r\n 235:             \"required\": {\r\n 236:                 \"source_bank_id\": (_bank_choices(), {\"default\": \"media_archive\"}),\r\n 237:                 \"story_model_id\": (_model_choices(), {\"default\": \"auto\"}),\r\n 238:                 \"story_pipeline_id\": (_pipeline_choices(), {\"default\": \"auto\"}),\r\n 239:                 \"visual_style_id\": (_style_choices(), {\"default\": \"auto\"}),\r\n 240:             },\r\n 241:         }\r\n 242: \r\n 243:     @classmethod\r\n 244:     def IS_CHANGED(cls, **kwargs: Any) -> str:\r\n 245:         return _lab_state_digest()\r\n 246: \r\n 247:     def emit(self, source_bank_id: str, story_model_id: str,\r\n 248:              story_pipeline_id: str, visual_style_id: str) -> tuple[str]:\r\n 249:         _ensure_lab_importable()\r\n 250:         from upstream_story_lab.bridge import (\r\n 251:             build_bridge_artifact,\r\n 252:             build_spec,\r\n 253:             emit_bridge_artifact,\r\n 254:         )\r\n 255: \r\n 256:         registry = _registry()\r\n 257:         spec = build_spec(\r\n 258:             registry,\r\n 259:             source_bank_id=source_bank_id,\r\n 260:             story_model_id=story_model_id,\r\n 261:             story_pipeline_id=story_pipeline_id,\r\n 262:             visual_style_id=visual_style_id,\r\n 263:         )\r\n 264:         artifact = build_bridge_artifact(spec)\r\n 265:         out = LAB_ROOT / \"bridge_out\" / (\r\n 266:             f\"bridge_{spec.source_bank_id}_{spec.story_model_id}.json\"\r\n 267:         )\r\n 268:         path = emit_bridge_artifact(artifact, out)\r\n 269:         return (str(path),)\r\n 270: \r\n 271: \r\n 272: NODE_CLASS_MAPPINGS = {\r\n 273:     \"OTR_UpstreamStoryLabValidator\": OTR_UpstreamStoryLabValidator,\r\n 274:     \"OTR_StoryPackPreview\": OTR_StoryPackPreview,\r\n 275:     \"OTR_BridgeArtifactEmit\": OTR_BridgeArtifactEmit,\r\n 276: }\r\n 277: \r\n 278: NODE_DISPLAY_NAME_MAPPINGS = {\r\n 279:     \"OTR_UpstreamStoryLabValidator\": \"OTR Upstream Story Lab Validator (v2)\",\r\n 280:     \"OTR_StoryPackPreview\": \"OTR Story Pack Preview (v2)\",\r\n 281:     \"OTR_BridgeArtifactEmit\": \"OTR Bridge Artifact Emit (v2)\",\r\n 282: }\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'src\\\\upstream_story_lab\\\\bridge.py' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"\"\"Translator head: assemble a validated LedgerWritingSpec and emit the one\r\n   2: frozen bridge artifact production will consume at transplant time.\r\n   3: \r\n   4: Refuses to emit anything partial. Mirror shapes are pinned in compat.py and\r\n   5: drift-tested; the bridge maps StoryInputPacket.close_brief ->\r\n   6: meta.news.news_close_brief explicitly (kibitz r2: production field name wins\r\n   7: at the mirror boundary).\r\n   8: \"\"\"\r\n   9: \r\n  10: from __future__ import annotations\r\n  11: \r\n  12: import json\r\n  13: from datetime import datetime, timezone\r\n  14: from pathlib import Path\r\n  15: \r\n  16: from .compat import (\r\n  17:     NEWS_ARTICLE_KEYS,\r\n  18:     NEWS_BRIEFS_FIELDS,\r\n  19:     NEWS_SEED_KEYS,\r\n  20:     canonical_json_hash,\r\n  21:     file_sha256,\r\n  22: )\r\n  23: from .contracts import (\r\n  24:     BridgeArtifact,\r\n  25:     LedgerWritingSpec,\r\n  26:     MetaMirrors,\r\n  27:     Provenance,\r\n  28:     SourceMaterialPacket,\r\n  29: )\r\n  30: from .interpreters import resolve_interpreter\r\n  31: from .profiles import resolve_profile\r\n  32: from .registry import Registry\r\n  33: \r\n  34: \r\n  35: class BridgeError(ValueError):\r\n  36:     \"\"\"Fail-loud bridge assembly/emission problem.\"\"\"\r\n  37: \r\n  38: \r\n  39: def build_spec(registry: Registry, *, source_bank_id: str,\r\n  40:                story_model_id: str = \"auto\", story_pipeline_id: str = \"auto\",\r\n  41:                visual_style_id: str = \"auto\",\r\n  42:                packet: SourceMaterialPacket | None = None,\r\n  43:                production_baseline: str = \"\") -> LedgerWritingSpec:\r\n  44:     \"\"\"Resolve ids, interpret source, and assemble a cross-validated spec.\"\"\"\r\n  45: \r\n  46:     resolution = registry.resolve(\r\n  47:         source_bank_id=source_bank_id,\r\n  48:         story_model_id=story_model_id,\r\n  49:         story_pipeline_id=story_pipeline_id,\r\n  50:         visual_style_id=visual_style_id,\r\n  51:     )\r\n  52:     bank_id = resolution.resolved(\"source_bank\")\r\n  53:     model_id = resolution.resolved(\"story_model\")\r\n  54:     pipeline_id = resolution.resolved(\"story_pipeline\")\r\n  55:     style_id = resolution.resolved(\"visual_style\")\r\n  56: \r\n  57:     bank = registry.bank(bank_id)\r\n  58:     if packet is None:\r\n  59:         packet, packet_path = registry.source_packet(bank_id)\r\n  60:     else:\r\n  61:         packet_path = None\r\n  62:     interpreter = resolve_interpreter(bank)\r\n  63:     story_input = interpreter(packet, bank, None, story_model_id=model_id)\r\n  64:     profile = resolve_profile(registry, bank_id, model_id, pipeline_id)\r\n  65:     policy = registry.style(style_id)\r\n  66:     pipeline = registry.pipeline(pipeline_id)\r\n  67: \r\n  68:     provenance = Provenance(\r\n  69:         production_baseline=production_baseline,\r\n  70:         lab_state_digest=registry.state_digest(),\r\n  71:         pack_sha256=file_sha256(registry.pack_path(bank_id, model_id, pipeline_id)),\r\n  72:         style_sha256=file_sha256(registry.style_path(style_id)),\r\n  73:         packet_sha256=(\r\n  74:             file_sha256(packet_path) if packet_path is not None\r\n  75:             else canonical_json_hash(packet.model_dump(mode=\"json\"))\r\n  76:         ),\r\n  77:         **registry.fixture_hashes(),\r\n  78:     )\r\n  79: \r\n  80:     return LedgerWritingSpec(\r\n  81:         source_bank_id=bank_id,\r\n  82:         story_model_id=model_id,\r\n  83:         story_pipeline_id=pipeline_id,\r\n  84:         visual_style_id=policy.style_id,\r\n  85:         source_material=packet,\r\n  86:         story_input=story_input,\r\n  87:         prompt_profile=profile,\r\n  88:         visual_policy=policy,\r\n  89:         slot_plan=list(pipeline.passes),\r\n  90:         resolution=resolution,\r\n  91:         provenance=provenance,\r\n  92:     )\r\n  93: \r\n  94: \r\n  95: def build_meta_mirrors(spec: LedgerWritingSpec, *, created_utc: str) -> MetaMirrors:\r\n  96:     \"\"\"Emit the two production meta shapes, complete (all keys, right types).\r\n  97: \r\n  98:     meta.news carries ALL 13 NewsBriefs fields; python-stamped fields get\r\n  99:     bridge-provenanced values. meta.news_seed carries all 7 documented keys\r\n 100:     (required consumer subset is headline+source; we emit everything).\"\"\"\r\n 101: \r\n 102:     material = spec.source_material\r\n 103:     story = spec.story_input\r\n 104:     news = {\r\n 105:         \"casting_brief\": story.casting_brief,\r\n 106:         \"script_brief\": story.script_brief,\r\n 107:         \"news_close_brief\": story.close_brief,  # explicit mapping (kibitz r2)\r\n 108:         \"key_terms\": list(story.key_terms),\r\n 109:         \"source_hash\": material.source_hash,\r\n 110:         \"source_chars\": len(material.raw_text or material.source_summary),\r\n 111:         \"prompt_version\": \"bridge-v2\",\r\n 112:         \"schema_version\": \"bridge-v2\",\r\n 113:         \"model_id\": \"\",\r\n 114:         \"decoder_profile\": \"\",\r\n 115:         \"seed\": 0,\r\n 116:         \"attempts\": 0,\r\n 117:         \"attempt_failures\": [],\r\n 118:     }\r\n 119:     if set(news) != set(NEWS_BRIEFS_FIELDS):\r\n 120:         raise BridgeError(\r\n 121:             \"meta.news mirror keys drifted from pinned NewsBriefs fields: \"\r\n 122:             f\"{sorted(set(news) ^ set(NEWS_BRIEFS_FIELDS))}\"\r\n 123:         )\r\n 124:     if not isinstance(news[\"key_terms\"], list):\r\n 125:         raise BridgeError(\"meta.news.key_terms must be a list (freeze invariant)\")\r\n 126: \r\n 127:     news_seed = {\r\n 128:         \"headline\": material.source_title,\r\n 129:         \"source\": material.source_label or material.source_author or \"bridge\",\r\n 130:         \"url\": material.source_url,\r\n 131:         \"date\": \"\",\r\n 132:         \"body_chars\": len(material.raw_text),\r\n 133:         \"style\": \"\",\r\n 134:         \"selected_at\": created_utc,\r\n 135:     }\r\n 136:     if set(news_seed) != set(NEWS_SEED_KEYS):\r\n 137:         raise BridgeError(\r\n 138:             \"meta.news_seed mirror keys drifted from pinned shape: \"\r\n 139:             f\"{sorted(set(news_seed) ^ set(NEWS_SEED_KEYS))}\"\r\n 140:         )\r\n 141:     return MetaMirrors(news=news, news_seed=news_seed)\r\n 142: \r\n 143: \r\n 144: def build_adapter_news_article(spec: LedgerWritingSpec) -> dict:\r\n 145:     \"\"\"The writer-internal article dict (custom_premise-branch shape,\r\n 146:     writer :1338-1346): how packet-driven lanes enter production.\"\"\"\r\n 147: \r\n 148:     material = spec.source_material\r\n 149:     seed_text = \" \".join(\r\n 150:         p for p in (material.source_title, material.source_summary) if p\r\n 151:     ).strip() or material.raw_text.strip()\r\n 152:     if not seed_text:\r\n 153:         raise BridgeError(\r\n 154:             \"cannot build adapter article: packet has no title/summary/raw_text\"\r\n 155:         )\r\n 156:     article = {\r\n 157:         \"headline\": material.source_title,\r\n 158:         \"summary\": material.source_summary,\r\n 159:         \"full_text\": material.raw_text or material.source_summary,\r\n 160:         \"source\": material.source_label or \"Bridge Packet\",\r\n 161:         \"date\": \"\",\r\n 162:         \"link\": material.source_url,\r\n 163:         \"seed_text\": seed_text,\r\n 164:     }\r\n 165:     if set(article) != set(NEWS_ARTICLE_KEYS):\r\n 166:         raise BridgeError(\"adapter article keys drifted from pinned shape\")\r\n 167:     return article\r\n 168: \r\n 169: \r\n 170: def build_bridge_artifact(spec: LedgerWritingSpec) -> BridgeArtifact:\r\n 171:     created = datetime.now(timezone.utc).isoformat(timespec=\"seconds\")\r\n 172:     return BridgeArtifact(\r\n 173:         created_utc=created,\r\n 174:         ledger_writing_spec=spec,\r\n 175:         meta_mirrors=build_meta_mirrors(spec, created_utc=created),\r\n 176:         adapter_news_article=build_adapter_news_article(spec),\r\n 177:     )\r\n 178: \r\n 179: \r\n 180: def emit_bridge_artifact(artifact: BridgeArtifact, path: Path) -> Path:\r\n 181:     \"\"\"Write the artifact JSON: UTF-8, no BOM, LF, trailing newline.\"\"\"\r\n 182: \r\n 183:     payload = json.dumps(\r\n 184:         artifact.model_dump(mode=\"json\"), indent=2, ensure_ascii=False\r\n 185:     )\r\n 186:     path = Path(path)\r\n 187:     path.parent.mkdir(parents=True, exist_ok=True)\r\n 188:     with open(path, \"w\", encoding=\"utf-8\", newline=\"\\n\") as fh:\r\n 189:         fh.write(payload + \"\\n\")\r\n 190:     # Round-trip validation: the emitted file must re-validate or be deleted.\r\n 191:     try:\r\n 192:         BridgeArtifact(**json.loads(path.read_text(encoding=\"utf-8\")))\r\n 193:     except Exception as exc:\r\n 194:         path.unlink(missing_ok=True)\r\n 195:         raise BridgeError(f\"emitted bridge artifact failed round-trip: {exc}\") from exc\r\n 196:     return path\r\n","exit_code":0,"status":"completed"}}
