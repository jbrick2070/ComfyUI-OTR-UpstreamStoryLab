news_seed=news_seed)\r\n 167: \r\n 168: \r\n 169: def build_adapter_news_article(spec: LedgerWritingSpec) -> dict:\r\n 170:     \"\"\"The writer-internal article dict (custom_premise-branch shape,\r\n 171:     writer :1338-1346): how packet-driven lanes enter production.\"\"\"\r\n 172: \r\n 173:     material = spec.source_material\r\n 174:     seed_text = \" \".join(\r\n 175:         p for p in (material.source_title, material.source_summary) if p\r\n 176:     ).strip() or material.raw_text.strip()\r\n 177:     if not seed_text:\r\n 178:         raise BridgeError(\r\n 179:             \"cannot build adapter article: packet has no title/summary/raw_text\"\r\n 180:         )\r\n 181:     article = {\r\n 182:         \"headline\": material.source_title,\r\n 183:         \"summary\": material.source_summary,\r\n 184:         \"full_text\": material.raw_text or material.source_summary,\r\n 185:         \"source\": material.source_label or \"Bridge Packet\",\r\n 186:         \"date\": \"\",\r\n 187:         \"link\": material.source_url,\r\n 188:         \"seed_text\": seed_text,\r\n 189:     }\r\n 190:     if set(article) != set(NEWS_ARTICLE_KEYS):\r\n 191:         raise BridgeError(\"adapter article keys drifted from pinned shape\")\r\n 192:     return article\r\n 193: \r\n 194: \r\n 195: def build_bridge_artifact(spec: LedgerWritingSpec) -> BridgeArtifact:\r\n 196:     created = datetime.now(timezone.utc).isoformat(timespec=\"seconds\")\r\n 197:     return BridgeArtifact(\r\n 198:         created_utc=created,\r\n 199:         ledger_writing_spec=spec,\r\n 200:         meta_mirrors=build_meta_mirrors(spec, created_utc=created),\r\n 201:         adapter_news_article=build_adapter_news_article(spec),\r\n 202:     )\r\n 203: \r\n 204: \r\n 205: def emit_bridge_artifact(artifact: BridgeArtifact, path: Path) -> Path:\r\n 206:     \"\"\"Write the artifact JSON: UTF-8, no BOM, LF, trailing newline.\"\"\"\r\n 207: \r\n 208:     payload = json.dumps(\r\n 209:         artifact.mo