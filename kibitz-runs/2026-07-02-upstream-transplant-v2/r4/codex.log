{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=1; Get-Content -LiteralPath '\"'transplant_work\\\\production_new_modules\\\\_otr_ledger_input_adapter.py' | ForEach-Object { '{0,4}: {1}' -f \"'$i++, $_ }'","aggregated_output":"   1: \"\"\"Bridge-artifact validator for the OTR upstream transplant.\r\n   2: \r\n   3: DESTINATION: ComfyUI-OldTimeRadio/nodes/_otr_ledger_input_adapter.py\r\n   4: STATUS: staged in the lab (transplant_work/); NOT installed in production yet.\r\n   5: \r\n   6: Validates one frozen bridge artifact (the upstream lab's translator-head\r\n   7: output) before any production code consumes it. Pure stdlib + optional\r\n   8: injected model classes - it never imports the lab and only touches production\r\n   9: models the caller explicitly passes in (production wires NewsBriefs; lab\r\n  10: tests pass None and get pinned key-set validation instead - an explicit\r\n  11: parameter, not a hidden fallback).\r\n  12: \"\"\"\r\n  13: \r\n  14: from __future__ import annotations\r\n  15: \r\n  16: import json\r\n  17: from pathlib import Path\r\n  18: from typing import Any, Callable\r\n  19: \r\n  20: #: Pinned to production news_interpreter.NewsBriefs (13 fields). The caller\r\n  21: #: may pass the real model class for full validation; the pin guards key-set\r\n  22: #: shape when the model is not supplied (lab-side tests).\r\n  23: NEWS_BRIEFS_FIELDS = (\r\n  24:     \"casting_brief\", \"script_brief\", \"news_close_brief\", \"key_terms\",\r\n  25:     \"source_hash\", \"source_chars\", \"prompt_version\", \"schema_version\",\r\n  26:     \"model_id\", \"decoder_profile\", \"seed\", \"attempts\", \"attempt_failures\",\r\n  27: )\r\n  28: NEWS_SEED_KEYS = (\r\n  29:     \"headline\", \"source\", \"url\", \"date\", \"body_chars\", \"style\", \"selected_at\",\r\n  30: )\r\n  31: NEWS_ARTICLE_KEYS = (\r\n  32:     \"headline\", \"summary\", \"full_text\", \"source\", \"date\", \"link\", \"seed_text\",\r\n  33: )\r\n  34: REQUIRED_TOP_LEVEL = (\r\n  35:     \"schema_version\", \"created_utc\", \"ledger_writing_spec\", \"meta_mirrors\",\r\n  36:     \"adapter_news_article\",\r\n  37: )\r\n  38: REQUIRED_SPEC_IDS = (\r\n  39:     \"source_bank_id\", \"story_model_id\", \"story_pipeline_id\", \"visual_style_id\",\r\n  40: )\r\n  41: SUPPORTED_SCHEMA_VERSIONS = (\"v2.0\",)\r\n  42: \r\n  43: \r\n  44: class BridgeInputError(ValueError):\r\n  45:     \"\"\"The bridge artifact is unusable. Message says exactly why. There is no\r\n  46:     partial acceptance and no fallback payload.\"\"\"\r\n  47: \r\n  48: \r\n  49: def _require(condition: bool, message: str) -> None:\r\n  50:     if not condition:\r\n  51:         raise BridgeInputError(message)\r\n  52: \r\n  53: \r\n  54: def load_bridge_artifact(\r\n  55:     path: str | Path,\r\n  56:     *,\r\n  57:     news_briefs_model: Callable[..., Any] | None = None,\r\n  58: ) -> dict[str, Any]:\r\n  59:     \"\"\"Load a bridge artifact JSON file from an EXPLICIT path (the writer's\r\n  60:     forceInput socket value - never a scanned folder) and validate it.\r\n  61:     This is the one production entry point for file handoff (kibitz r3:\r\n  62:     emit writes a path, production consumes a path; one contract).\"\"\"\r\n  63: \r\n  64:     p = Path(path)\r\n  65:     if not p.is_file():\r\n  66:         raise BridgeInputError(f\"bridge artifact file not found: {p}\")\r\n  67:     raw = p.read_bytes()\r\n  68:     if raw[:3] == b\"\\xef\\xbb\\xbf\":\r\n  69:         raise BridgeInputError(f\"bridge artifact has a UTF-8 BOM: {p}\")\r\n  70:     try:\r\n  71:         data = json.loads(raw.decode(\"utf-8\"))\r\n  72:     except (UnicodeDecodeError, json.JSONDecodeError) as exc:\r\n  73:         raise BridgeInputError(f\"bridge artifact is not valid UTF-8 JSON: {p}: {exc}\") from exc\r\n  74:     return validate_bridge_artifact(data, news_briefs_model=news_briefs_model)\r\n  75: \r\n  76: \r\n  77: def validate_bridge_artifact(\r\n  78:     data: dict[str, Any],\r\n  79:     *,\r\n  80:     news_briefs_model: Callable[..., Any] | None = None,\r\n  81: ) -> dict[str, Any]:\r\n  82:     \"\"\"Validate and return the artifact dict; raise BridgeInputError on any\r\n  83:     defect. `news_briefs_model` is the production NewsBriefs class when\r\n  84:     called from production code (strongest validation path).\"\"\"\r\n  85: \r\n  86:     _require(isinstance(data, dict), \"bridge artifact must be a JSON object\")\r\n  87:     missing = [k for k in REQUIRED_TOP_LEVEL if k not in data]\r\n  88:     _require(not missing, f\"bridge artifact missing top-level keys: {missing}\")\r\n  89:     _require(\r\n  90:         data[\"schema_version\"] in SUPPORTED_SCHEMA_VERSIONS,\r\n  91:         f\"unsupported bridge schema_version {data['schema_version']!r}; \"\r\n  92:         f\"supported: {SUPPORTED_SCHEMA_VERSIONS}\",\r\n  93:     )\r\n  94: \r\n  95:     spec = data[\"ledger_writing_spec\"]\r\n  96:     _require(isinstance(spec, dict), \"ledger_writing_spec must be an object\")\r\n  97:     for key in REQUIRED_SPEC_IDS:\r\n  98:         _require(\r\n  99:             bool(str(spec.get(key, \"\")).strip()),\r\n 100:             f\"ledger_writing_spec.{key} is required and empty\",\r\n 101:         )\r\n 102:     profile = spec.get(\"prompt_profile\")\r\n 103:     _require(isinstance(profile, dict), \"ledger_writing_spec.prompt_profile missing\")\r\n 104:     for key in (\"source_bank_id\", \"story_model_id\"):\r\n 105:         _require(\r\n 106:             profile.get(key) == spec.get(key),\r\n 107:             f\"prompt_profile.{key} != spec.{key} - refusing inconsistent spec\",\r\n 108:         )\r\n 109:     policy = spec.get(\"visual_policy\")\r\n 110:     _require(isinstance(policy, dict), \"ledger_writing_spec.visual_policy missing\")\r\n 111:     _require(\r\n 112:         policy.get(\"style_id\") == spec.get(\"visual_style_id\"),\r\n 113:         \"visual_policy.style_id != spec.visual_style_id\",\r\n 114:     )\r\n 115: \r\n 116:     mirrors = data[\"meta_mirrors\"]\r\n 117:     _require(isinstance(mirrors, dict), \"meta_mirrors must be an object\")\r\n 118:     news = mirrors.get(\"news\")\r\n 119:     _require(isinstance(news, dict), \"meta_mirrors.news missing\")\r\n 120:     if news_briefs_model is not None:\r\n 121:         try:\r\n 122:             news_briefs_model(**news)\r\n 123:         except Exception as exc:\r\n 124:             raise BridgeInputError(\r\n 125:                 f\"meta_mirrors.news failed NewsBriefs validation: {exc}\"\r\n 126:             ) from exc\r\n 127:     else:\r\n 128:         _require(\r\n 129:             set(news) == set(NEWS_BRIEFS_FIELDS),\r\n 130:             \"meta_mirrors.news keys != NewsBriefs fields: \"\r\n 131:             f\"{sorted(set(news) ^ set(NEWS_BRIEFS_FIELDS))}\",\r\n 132:         )\r\n 133:     _require(isinstance(news.get(\"key_terms\"), list),\r\n 134:              \"meta_mirrors.news.key_terms must be a list (freeze invariant)\")\r\n 135: \r\n 136:     seed = mirrors.get(\"news_seed\")\r\n 137:     _require(isinstance(seed, dict), \"meta_mirrors.news_seed missing\")\r\n 138:     _require(\r\n 139:         set(seed) == set(NEWS_SEED_KEYS),\r\n 140:         f\"meta_mirrors.news_seed keys drifted: {sorted(set(seed) ^ set(NEWS_SEED_KEYS))}\",\r\n 141:     )\r\n 142:     _require(bool(str(seed.get(\"headline\", \"\")).strip()),\r\n 143:              \"meta_mirrors.news_seed.headline is required (consumer-read key)\")\r\n 144: \r\n 145:     article = data[\"adapter_news_article\"]\r\n 146:     _require(isinstance(article, dict), \"adapter_news_article must be an object\")\r\n 147:     _require(\r\n 148:         set(article) == set(NEWS_ARTICLE_KEYS),\r\n 149:         f\"adapter_news_article keys drifted: {sorted(set(article) ^ set(NEWS_ARTICLE_KEYS))}\",\r\n 150:     )\r\n 151:     _require(bool(str(article.get(\"seed_text\", \"\")).strip()),\r\n 152:              \"adapter_news_article.seed_text is required and empty\")\r\n 153:     return data\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=1; Get-Content -LiteralPath '\"'src\\\\upstream_story_lab\\\\contracts.py' | ForEach-Object { '{0,4}: {1}' -f \"'$i++, $_ }'","aggregated_output":"   1: \"\"\"Strict contracts for the upstream story lab v2 (transplant workspace).\r\n   2: \r\n   3: JSON owns content and configuration. Python owns validation, routing,\r\n   4: execution, and fail-loud errors. No fallbacks. No hidden models or engines.\r\n   5: \r\n   6: Vocabulary lock (kibitz r1 2026-07-02): `story_model` is the dramatic/tonal\r\n   7: lane; LLM engines are SLOT MODELS (creative/technical) resolved at runtime by\r\n   8: the production node widgets. The lab declares a slot plan, never engine ids.\r\n   9: \"\"\"\r\n  10: \r\n  11: from __future__ import annotations\r\n  12: \r\n  13: from typing import Any, Literal\r\n  14: \r\n  15: from pydantic import BaseModel, ConfigDict, Field, model_validator\r\n  16: \r\n  17: SCHEMA_VERSION = \"v2.0\"\r\n  18: \r\n  19: #: Slot roles an LLM-touching pass may declare. Engine ids are runtime-owned.\r\n  20: SlotRole = Literal[\"creative\", \"technical\"]\r\n  21: \r\n  22: #: Prompt template seams a story pack may own (kibitz r1: templates only -\r\n  23: #: generated content fields like casting_brief are interpreter OUTPUT, not\r\n  24: #: seams). Keys match v1 `prompt_stages` for add-only migration.\r\n  25: TEMPLATE_SEAMS = (\r\n  26:     \"outline_system\",\r\n  27:     \"pitch_room_system\",\r\n  28:     \"story_select_system\",\r\n  29:     \"dramatic_state_system\",\r\n  30:     \"line_grounding\",\r\n  31:     \"coda_system\",\r\n  32:     \"title_system\",\r\n  33:     \"style_pick_inventor\",\r\n  34:     \"style_pick_chooser\",\r\n  35:     \"style_pick_chooser_user_template\",\r\n  36:     # simple_4_prompt_experimental pass prompts (pipeline-executable seams;\r\n  37:     # adaptive-cleanup was CUT to documentation-only in kibitz r1).\r\n  38:     \"pass_1_creative_story\",\r\n  39:     \"pass_2_creative_ledger_fill\",\r\n  40:     \"pass_3_technical_schema_cleanup\",\r\n  41:     \"pass_4_technical_ledger_audit\",\r\n  42: )\r\n  43: \r\n  44: #: Label variables usable in ANY seam template (substituted from the resolved\r\n  45: #: profile). Kibitz r2 (Codex, confirmed): some production templates carry\r\n  46: #: RUNTIME variables filled at the call site - those are declared per seam\r\n  47: #: below, sourced from production_mirror/nodes/_otr_style_picker.py:301,:334.\r\n  48: LABEL_TEMPLATE_VARIABLES = frozenset(\r\n  49:     {\r\n  50:         \"story_form_label\",\r\n  51:         \"source_material_label\",\r\n  52:         \"source_develop_verb\",\r\n  53:         \"source_grounding_label\",\r\n  54:         \"key_terms_label\",\r\n  55:         \"close_brief_label\",\r\n  56:         \"title_form_label\",\r\n  57:     }\r\n  58: )\r\n  59: SEAM_RUNTIME_VARIABLES: dict[str, frozenset[str]] = {\r\n  60:     \"style_pick_inventor\": frozenset(\r\n  61:         {\"n_required\", \"seed_sample_block\", \"article_excerpt\"}\r\n  62:     ),\r\n  63:     \"style_pick_chooser\": frozenset(\r\n  64:         {\"article_excerpt\", \"candidates_block\", \"story_summary\"}\r\n  65:     ),\r\n  66:     \"style_pick_chooser_user_template\": frozenset(\r\n  67:         {\"article_excerpt\", \"candidates_block\", \"story_summary\"}\r\n  68:     ),\r\n  69: }\r\n  70: \r\n  71: \r\n  72: def allowed_seam_variables(seam: str) -> frozenset[str]:\r\n  73:     \"\"\"Per-seam template variable allowlist (labels + declared runtime).\"\"\"\r\n  74: \r\n  75:     return LABEL_TEMPLATE_VARIABLES | SEAM_RUNTIME_VARIABLES.get(seam, frozenset())\r\n  76: \r\n  77: #: Motion-prompt role keys allowed in a visual policy. Pinned to the\r\n  78: #: production vocabulary (render_driver._LTX_MOTION_PROMPT_BY_ROLE) plus the\r\n  79: #: forward-declared lipsync/character keys the visual stage will define.\r\n  80: #: Dead roles (sfx, scene_broll, background_abstract) must stay dead.\r\n  81: ALLOWED_MOTION_ROLE_KEYS = frozenset(\r\n  82:     {\"announcer\", \"music_open\", \"music_close\", \"music_inter\"}\r\n  83: )\r\n  84: \r\n  85: CODA_MODES = (\"real_news_report\", \"archive_source_note\", \"source_attribution\", \"none\")\r\n  86: \r\n  87: \r\n  88: class SourceMaterialPacket(BaseModel):\r\n  89:     \"\"\"Raw source material before interpretation.\"\"\"\r\n  90: \r\n  91:     model_config = ConfigDict(extra=\"forbid\")\r\n  92: \r\n  93:     schema_version: str = SCHEMA_VERSION\r\n  94:     packet_version: int = 1\r\n  95:     source_bank_id: str\r\n  96:     source_mode: str = \"fixture\"\r\n  97:     source_kind: str = \"\"\r\n  98:     source_label: str = \"\"\r\n  99:     rights_status: Literal[\r\n 100:         \"unknown\", \"public_domain\", \"licensed\", \"fair_use_research\"\r\n 101:     ] = \"unknown\"\r\n 102:     source_title: str = \"\"\r\n 103:     source_author: str = \"\"\r\n 104:     source_url: str = \"\"\r\n 105:     source_hash: str = \"\"\r\n 106:     source_text_ref: str = \"\"\r\n 107:     source_summary: str = \"\"\r\n 108:     raw_text: str = \"\"\r\n 109:     # Fixture-brief block (kibitz FABLE review SHOULD-FIX: fixture briefs are\r\n 110:     # content and live in the packet JSON, not in Python).\r\n 111:     fixture_casting_brief: str = \"\"\r\n 112:     fixture_script_brief: str = \"\"\r\n 113:     fixture_close_brief: str = \"\"\r\n 114:     fixture_key_terms: list[str] = Field(default_factory=list)\r\n 115:     fixture_fidelity_rules: list[str] = Field(default_factory=list)\r\n 116: \r\n 117: \r\n 118: class PublicDomainSourceManifest(BaseModel):\r\n 119:     \"\"\"Source-folder manifest for public-domain books, comics, plays, etc.\r\n 120: \r\n 121:     PD packets are FILE-BACKED: `text_files`/`image_files` are relative\r\n 122:     POSIX-style paths inside the manifest folder; absolute paths and `..`\r\n 123:     components are rejected by the registry (v1 rule preserved).\r\n 124:     \"\"\"\r\n 125: \r\n 126:     model_config = ConfigDict(extra=\"forbid\")\r\n 127: \r\n 128:     schema_version: str = SCHEMA_VERSION\r\n 129:     source_id: str\r\n 130:     source_bank_id: Literal[\"public_domain_story\"] = \"public_domain_story\"\r\n 131:     source_kind: str\r\n 132:     title: str\r\n 133:     author: str = \"\"\r\n 134:     publication_year: int | None = None\r\n 135:     rights_status: Literal[\"public_domain\"] = \"public_domain\"\r\n 136:     source_url: str = \"\"\r\n 137:     text_files: list[str] = Field(default_factory=list)\r\n 138:     image_files: list[str] = Field(default_factory=list)\r\n 139:     adaptation_mode: str\r\n 140:     required_fidelity: list[str] = Field(default_factory=list)\r\n 141: \r\n 142: \r\n 143: class BankDefaults(BaseModel):\r\n 144:     \"\"\"Bank-level label/coda defaults; packs override single-level.\"\"\"\r\n 145: \r\n 146:     model_config = ConfigDict(extra=\"forbid\")\r\n 147: \r\n 148:     story_form_label: str = \"\"\r\n 149:     source_material_label: str = \"\"\r\n 150:     source_develop_verb: str = \"\"\r\n 151:     source_grounding_label: str = \"\"\r\n 152:     key_terms_label: str = \"KEY TERMS\"\r\n 153:     close_brief_label: str = \"source note\"\r\n 154:     title_form_label: str = \"\"\r\n 155:     coda_mode: str = \"\"\r\n 156: \r\n 157: \r\n 158: class SourceBankSpec(BaseModel):\r\n 159:     \"\"\"One source bank, declared in fixtures/banks.json.\"\"\"\r\n 160: \r\n 161:     model_config = ConfigDict(extra=\"forbid\")\r\n 162: \r\n 163:     schema_version: str = SCHEMA_VERSION\r\n 164:     source_bank_id: str\r\n 165:     label: str\r\n 166:     dropdown_label: str = \"\"\r\n 167:     source_kind: str = \"\"\r\n 168:     #: Named Python behavior bindings, resolved through an explicit\r\n 169:     #: allowlist registry. Unknown binding = hard error.\r\n 170:     interpreter: str\r\n 171:     #: Fetcher binding; empty string means packet-driven only (v1 scope:\r\n 172:     #: only science_news declares a fetcher).\r\n 173:     fetcher: str = \"\"\r\n 174:     default_story_model: str\r\n 175:     default_visual_style: str\r\n 176:     default_story_pipeline: str = \"legacy_many_pass\"\r\n 177:     defaults: BankDefaults = Field(default_factory=BankDefaults)\r\n 178:     #: Seams every pack of this bank MUST supply (no invented default prose).\r\n 179:     required_seams: list[str] = Field(default_factory=list)\r\n 180:     runnable: bool = True\r\n 181:     guide_ref: str = \"\"\r\n 182: \r\n 183:     @model_validator(mode=\"after\")\r\n 184:     def _seams_known_and_runnable_bound(self) -> \"SourceBankSpec\":\r\n 185:         unknown = [s for s in self.required_seams if s not in TEMPLATE_SEAMS]\r\n 186:         if unknown:\r\n 187:             raise ValueError(\r\n 188:                 f\"bank {self.source_bank_id!r} requires unknown seams: {unknown}; \"\r\n 189:                 f\"known seams: {sorted(TEMPLATE_SEAMS)}\"\r\n 190:             )\r\n 191:         if self.runnable and not self.interpreter.strip():\r\n 192:             raise ValueError(\r\n 193:                 f\"bank {self.source_bank_id!r} is runnable but declares no \"\r\n 194:                 \"interpreter binding\"\r\n 195:             )\r\n 196:         return self\r\n 197: \r\n 198: \r\n 199: class StoryPack(BaseModel):\r\n 200:     \"\"\"Cloneable prompt/content pack for one (bank, model, pipeline) lane.\r\n 201: \r\n 202:     v1-compatible: `prompt_stages` keeps its name and v1 keys; v2 adds\r\n 203:     labels/coda fields so the pack is the single content source the resolved\r\n 204:     StoryPromptProfile is built from (no Python prose anywhere).\r\n 205:     \"\"\"\r\n 206: \r\n 207:     model_config = ConfigDict(extra=\"forbid\")\r\n 208: \r\n 209:     schema_version: str = SCHEMA_VERSION\r\n 210:     source_bank_id: str\r\n 211:     story_model_id: str\r\n 212:     story_pipeline_id: str = \"legacy_many_pass\"\r\n 213:     label: str\r\n 214:     status: Literal[\"ready_fixture\", \"experimental\", \"not_implemented\"] = (\r\n 215:         \"ready_fixture\"\r\n 216:     )\r\n 217:     prompt_stages: dict[str, str] = Field(default_factory=dict)\r\n 218:     #: Label overrides (single-level over bank defaults; empty = inherit).\r\n 219:     labels: BankDefaults = Field(default_factory=BankDefaults)\r\n 220:     coda_mode: str = \"\"\r\n 221:     coda_examples: list[str] = Field(default_factory=list)\r\n 222:     outline_rules_extra: str = \"\"\r\n 223:     examples: list[str] = Field(default_factory=list)\r\n 224:     tone_guardrails: list[str] = Field(default_factory=list)\r\n 225:     forbidden_plot_patterns: list[str] = Field(default_factory=list)\r\n 226:     forbidden_leakage_terms: list[str] = Field(default_factory=list)\r\n 227:     source_requirements: list[str] = Field(default_factory=list)\r\n 228:     ledger_validation_notes: list[str] = Field(default_factory=list)\r\n 229: \r\n 230:     @model_validator(mode=\"after\")\r\n 231:     def _stages_known_and_coda_valid(self) -> \"StoryPack\":\r\n 232:         unknown = sorted(set(self.prompt_stages) - set(TEMPLATE_SEAMS))\r\n 233:         if unknown:\r\n 234:             raise ValueError(\r\n 235:                 f\"pack {self.story_model_id!r} has unknown prompt_stages keys: \"\r\n 236:                 f\"{unknown}; allowed: {sorted(TEMPLATE_SEAMS)}\"\r\n 237:             )\r\n 238:         if self.coda_mode and self.coda_mode not in CODA_MODES:\r\n 239:             raise ValueError(\r\n 240:                 f\"pack {self.story_model_id!r} coda_mode {self.coda_mode!r} \"\r\n 241:                 f\"not in {CODA_MODES}\"\r\n 242:             )\r\n 243:         return self\r\n 244: \r\n 245: \r\n 246: class StoryPromptProfile(BaseModel):\r\n 247:     \"\"\"RESOLVED view of (bank defaults + pack). Field names are locked to the\r\n 248:     v1/pre-SFX-r4 vocabulary because production OutlineRequest/adapter code\r\n 249:     is planned against them. Built by profiles.resolve_profile(); contains\r\n 250:     no Python-authored prose.\"\"\"\r\n 251: \r\n 252:     model_config = ConfigDict(extra=\"forbid\")\r\n 253: \r\n 254:     source_bank_id: str\r\n 255:     story_model_id: str\r\n 256:     story_form_label: str\r\n 257:     source_material_label: str\r\n 258:     source_develop_verb: str\r\n 259:     source_grounding_label: str\r\n 260:     key_terms_label: str = \"KEY TERMS\"\r\n 261:     close_brief_label: str = \"source note\"\r\n 262:     coda_mode: Literal[\r\n 263:         \"real_news_report\", \"archive_source_note\", \"source_attribution\", \"none\"\r\n 264:     ]\r\n 265:     title_form_label: str\r\n 266:     line_grounding_instruction: str\r\n 267:     outline_rules_extra: str = \"\"\r\n 268:     tone_guardrails: list[str] = Field(default_factory=list)\r\n 269:     forbidden_plot_patterns: list[str] = Field(default_factory=list)\r\n 270:     outline_system_prompt: str | None = None\r\n 271:     pitch_room_system_prompt: str | None = None\r\n 272:     story_select_system_prompt: str | None = None\r\n 273:     dramatic_state_system_prompt: str | None = None\r\n 274:     coda_system_prompt: str | None = None\r\n 275:     coda_examples: list[str] = Field(default_factory=list)\r\n 276:     title_system_prompt: str | None = None\r\n 277:     style_picker_inventor_system_prompt: str | None = None\r\n 278:     style_picker_chooser_system_prompt: str | None = None\r\n 279:     style_picker_chooser_user_template: str | None = None\r\n 280: \r\n 281: \r\n 282: class StoryInputPacket(BaseModel):\r\n 283:     \"\"\"Interpreted story material ready for a ledger-writing spec.\r\n 284: \r\n 285:     casting_brief/script_brief/close_brief/key_terms are GENERATED CONTENT\r\n 286:     FIELDS (interpreter output), never pack templates (kibitz r1).\"\"\"\r\n 287: \r\n 288:     model_config = ConfigDict(extra=\"forbid\")\r\n 289: \r\n 290:     schema_version: str = SCHEMA_VERSION\r\n 291:     packet_version: int = 1\r\n 292:     source_bank_id: str\r\n 293:     story_model_id: str\r\n 294:     source_label: str = \"\"\r\n 295:     casting_brief: str = \"\"\r\n 296:     script_brief: str = \"\"\r\n 297:     close_brief: str = \"\"\r\n 298:     key_terms: list[str] = Field(default_factory=list)\r\n 299:     source_fidelity_rules: list[str] = Field(default_factory=list)\r\n 300:     adaptation_trace: dict[str, Any] = Field(default_factory=dict)\r\n 301:     source_material: SourceMaterialPacket\r\n 302: \r\n 303: \r\n 304: class VisualStylePolicy(BaseModel):\r\n 305:     \"\"\"Still/video rendering policy; independent axis from source/story.\"\"\"\r\n 306: \r\n 307:     model_config = ConfigDict(extra=\"forbid\")\r\n 308: \r\n 309:     schema_version: str = SCHEMA_VERSION\r\n 310:     style_id: str\r\n 311:     label: str = \"\"\r\n 312:     positive_tail: str = \"\"\r\n 313:     image_grade_tail: str = \"\"\r\n 314:     broadcast_tail: str = \"\"\r\n 315:     era_tail: str = \"\"\r\n 316:     allow_radio_tails: bool = True\r\n 317:     forbidden_terms: list[str] = Field(default_factory=list)\r\n 318:     announcer_visual_subject: str = \"\"\r\n 319:     music_visual_subject: str = \"\"\r\n 320:     scene_open_subject: str = \"\"\r\n 321:     character_portrait_style: str = \"\"\r\n 322:     character_scene_style: str = \"\"\r\n 323:     motion_prompts: dict[str, str] = Field(default_factory=dict)\r\n 324:     ledger_directives: dict[str, Any] = Field(default_factory=dict)\r\n 325: \r\n 326:     @model_validator(mode=\"after\")\r\n 327:     def _motion_keys_allowed(self) -> \"VisualStylePolicy\":\r\n 328:         unknown = sorted(set(self.motion_prompts) - ALLOWED_MOTION_ROLE_KEYS)\r\n 329:         if unknown:\r\n 330:             raise ValueError(\r\n 331:                 f\"visual style {self.style_id!r} motion_prompts has unknown \"\r\n 332:                 f\"role keys {unknown}; allowed: {sorted(ALLOWED_MOTION_ROLE_KEYS)} \"\r\n 333:                 \"(dead roles sfx/scene_broll/background_abstract must stay dead)\"\r\n 334:             )\r\n 335:         return self\r\n 336: \r\n 337: \r\n 338: class PassDecl(BaseModel):\r\n 339:     \"\"\"One declared pipeline pass. Descriptive passes document the\r\n 340:     production-native sequence; executable passes run in the lab runner.\"\"\"\r\n 341: \r\n 342:     model_config = ConfigDict(extra=\"forbid\")\r\n 343: \r\n 344:     pass_id: str\r\n 345:     slot: SlotRole\r\n 346:     seam_refs: list[str] = Field(default_factory=list)\r\n 347:     description: str = \"\"\r\n 348: \r\n 349:     @model_validator(mode=\"after\")\r\n 350:     def _seams_known(self) -> \"PassDecl\":\r\n 351:         unknown = [s for s in self.seam_refs if s not in TEMPLATE_SEAMS]\r\n 352:         if unknown:\r\n 353:             raise ValueError(\r\n 354:                 f\"pass {self.pass_id!r} references unknown seams: {unknown}\"\r\n 355:             )\r\n 356:         return self\r\n 357: \r\n 358: \r\n 359: class PipelineSpec(BaseModel):\r\n 360:     \"\"\"Declared pass structure. legacy_many_pass is DESCRIPTIVE (the\r\n 361:     production writer owns the real sequence; this is stamping/audit\r\n 362:     metadata). simple_4_prompt_experimental is lab-executable.\"\"\"\r\n 363: \r\n 364:     model_config = ConfigDict(extra=\"forbid\")\r\n 365: \r\n 366:     schema_version: str = SCHEMA_VERSION\r\n 367:     story_pipeline_id: str\r\n 368:     label: str\r\n 369:     executable_in_lab: bool = False\r\n 370:     passes: list[PassDecl] = Field(default_factory=list)\r\n 371:     notes: list[str] = Field(default_factory=list)\r\n 372: \r\n 373:     @model_validator(mode=\"after\")\r\n 374:     def _pass_ids_unique(self) -> \"PipelineSpec\":\r\n 375:         ids = [p.pass_id for p in self.passes]\r\n 376:         if len(ids) != len(set(ids)):\r\n 377:             raise ValueError(\r\n 378:                 f\"pipeline {self.story_pipeline_id!r} has duplicate pass ids\"\r\n 379:             )\r\n 380:         return self\r\n 381: \r\n 382: \r\n 383: class ResolutionDecision(BaseModel):\r\n 384:     \"\"\"One resolved id: what was asked, what was chosen, why, from where.\"\"\"\r\n 385: \r\n 386:     model_config = ConfigDict(extra=\"forbid\")\r\n 387: \r\n 388:     axis: Literal[\"source_bank\", \"story_model\", \"story_pipeline\", \"visual_style\"]\r\n 389:     requested: str\r\n 390:     resolved: str\r\n 391:     default_applied: bool\r\n 392:     decided_by: str  # e.g. \"explicit\", \"banks.json:default_story_model\"\r\n 393: \r\n 394: \r\n 395: class Resolution(BaseModel):\r\n 396:     \"\"\"Auditable record of every id decision (kibitz r1: 'auto' is data,\r\n 397:     not invisible behavior).\"\"\"\r\n 398: \r\n 399:     model_config = ConfigDict(extra=\"forbid\")\r\n 400: \r\n 401:     decisions: list[ResolutionDecision] = Field(default_factory=list)\r\n 402: \r\n 403:     def resolved(self, axis: str) -> str:\r\n 404:         for d in self.decisions:\r\n 405:             if d.axis == axis:\r\n 406:                 return d.resolved\r\n 407:         raise KeyError(f\"no resolution recorded for axis {axis!r}\")\r\n 408: \r\n 409: \r\n 410: class Provenance(BaseModel):\r\n 411:     \"\"\"Content hashes tying a spec to the exact JSON bytes that shaped it.\"\"\"\r\n 412: \r\n 413:     model_config = ConfigDict(extra=\"forbid\")\r\n 414: \r\n 415:     production_baseline: str = \"\"\r\n 416:     lab_state_digest: str = \"\"\r\n 417:     banks_sha256: str = \"\"\r\n 418:     pipelines_sha256: str = \"\"\r\n 419:     pack_sha256: str = \"\"\r\n 420:     style_sha256: str = \"\"\r\n 421:     packet_sha256: str = \"\"\r\n 422: \r\n 423: \r\n 424: class LedgerWritingSpec(BaseModel):\r\n 425:     \"\"\"Control plane for filling the existing production ledger.\"\"\"\r\n 426: \r\n 427:     model_config = ConfigDict(extra=\"forbid\")\r\n 428: \r\n 429:     schema_version: str = SCHEMA_VERSION\r\n 430:     source_bank_id: str\r\n 431:     story_model_id: str\r\n 432:     story_pipeline_id: str = \"legacy_many_pass\"\r\n 433:     visual_style_id: str = \"sci_fi_radio\"\r\n 434:     source_material: SourceMaterialPacket\r\n 435:     story_input: StoryInputPacket\r\n 436:     prompt_profile: StoryPromptProfile\r\n 437:     visual_policy: VisualStylePolicy\r\n 438:     slot_plan: list[PassDecl] = Field(default_factory=list)\r\n 439:     resolution: Resolution = Field(default_factory=Resolution)\r\n 440:     provenance: Provenance = Field(default_factory=Provenance)\r\n 441: \r\n 442:     @model_validator(mode=\"after\")\r\n 443:     def _ids_are_consistent(self) -> \"LedgerWritingSpec\":\r\n 444:         checks = [\r\n 445:             (\"visual_policy.style_id\", self.visual_policy.style_id, self.visual_style_id),\r\n 446:             (\"story_input.source_bank_id\", self.story_input.source_bank_id, self.source_bank_id),\r\n 447:             (\"story_input.story_model_id\", self.story_input.story_model_id, self.story_model_id),\r\n 448:             (\"prompt_profile.source_bank_id\", self.prompt_profile.source_bank_id, self.source_bank_id),\r\n 449:             (\"prompt_profile.story_model_id\", self.prompt_profile.story_model_id, self.story_model_id),\r\n 450:             (\"source_material.source_bank_id\", self.source_material.source_bank_id, self.source_bank_id),\r\n 451:         ]\r\n 452:         for name, got, want in checks:\r\n 453:             if got != want:\r\n 454:                 raise ValueError(f\"{name} must match spec: {got!r} != {want!r}\")\r\n 455:         return self\r\n 456: \r\n 457: \r\n 458: class MetaMirrors(BaseModel):\r\n 459:     \"\"\"The two production META compatibility shapes (kibitz r2: news_used is\r\n 460:     an output socket production derives from the outline at\r\n 461:     OTR_LedgerScriptWriter._build_news_payload - the bridge never fakes it).\r\n 462:     Key sets are pinned in compat.py and drift-tested against the mirror.\"\"\"\r\n 463: \r\n 464:     model_config = ConfigDict(extra=\"forbid\")\r\n 465: \r\n 466:     news: dict[str, Any]\r\n 467:     news_seed: dict[str, Any]\r\n 468: \r\n 469: \r\n 470: class FetchRequest(BaseModel):\r\n 471:     \"\"\"Runtime fetch hints for a bank fetcher binding (science-only in v1).\"\"\"\r\n 472: \r\n 473:     model_config = ConfigDict(extra=\"forbid\")\r\n 474: \r\n 475:     style_hint: str = \"\"\r\n 476:     model_hint: str = \"\"\r\n 477: \r\n 478: \r\n 479: class BridgeArtifact(BaseModel):\r\n 480:     \"\"\"The one frozen JSON file production consumes (translator-head output).\r\n 481:     Emitted only when every content/config JSON validated; never partial.\r\n 482: \r\n 483:     adapter_news_article is the writer-internal article-dict input shape -\r\n 484:     the same dict `_resolve_inputs` synthesizes on the custom_premise branch\r\n 485:     (writer :1338-1346) - so packet-driven lanes enter production through an\r\n 486:     existing, tested seam with seed_source='bridge_packet'.\"\"\"\r\n 487: \r\n 488:     model_config = ConfigDict(extra=\"forbid\")\r\n 489: \r\n 490:     schema_version: str = SCHEMA_VERSION\r\n 491:     created_utc: str\r\n 492:     ledger_writing_spec: LedgerWritingSpec\r\n 493:     meta_mirrors: MetaMirrors\r\n 494:     adapter_news_article: dict[str, Any]\r\n","exit_code":0,"status":"completed"}}
