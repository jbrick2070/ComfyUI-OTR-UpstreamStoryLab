labels.coda_mode or \"\").strip()\r\n  39:     if coda_mode not in CODA_MODES:\r\n  40:         raise RegistryError(\r\n  41:             f\"{pack_path}: no valid coda_mode resolved (pack={pack.coda_mode!r}, \"\r\n  42:             f\"bank default={bank.defaults.coda_mode!r}); allowed: {CODA_MODES}. \"\r\n  43:             \"No default coda is invented.\"\r\n  44:         )\r\n  45: \r\n  46:     required_labels = (\r\n  47:         \"story_form_label\",\r\n  48:         \"source_material_label\",\r\n  49:         \"source_develop_verb\",\r\n  50:         \"source_grounding_label\",\r\n  51:         \"title_form_label\",\r\n  52:     )\r\n  53:     missing = [f for f in required_labels if not str(getattr(labels, f)).strip()]\r\n  54:     if missing:\r\n  55:         raise RegistryError(\r\n  56:             f\"{pack_path}: unresolved required labels {missing} - supply them in \"\r\n  57:             \"the pack labels block or the bank defaults (JSON owns content).\"\r\n  58:         )\r\n  59: \r\n  60:     line_grounding = pack.prompt_stages.get(\"line_grounding\", \"\").strip()\r\n  61:     if not line_grounding:\r\n  62:         raise RegistryError(\r\n  63:             f\"{pack_path}: prompt_stages.line_grounding is required and empty - \"\r\n  64:             \"no grounding instruction is invented in Python.\"\r\n  65:         )\r\n  66: \r\n  67:     def stage(name: str) -> str | None:\r\n  68:         value = pack.prompt_stages.get(name, \"\").strip()\r\n  69:         return value or None\r\n  70: \r\n  71:     return StoryPromptProfile(\r\n  72:         source_bank_id=bank.source_bank_id,\r\n  73:         story_model_id=pack.story_model_id,\r\n  74:         story_form_label=labels.story_form_label,\r\n  75:         source_material_label=labels.source_material_label,\r\n  76:         source_develop_verb=labels.source_develop_verb,\r\n  77:         source_grounding_label=labels.source_grounding_label,\r\n  78:         key_terms_label=labels.key_terms_label,\r\