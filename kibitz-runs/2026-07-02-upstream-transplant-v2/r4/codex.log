t[str, Any]:\r\n  34:     if not isinstance(story_input, dict):\r\n  35:         raise SourceInterpreterError(\r\n  36:             f\"{bank_id}: bridge_story_input must be an object\"\r\n  37:         )\r\n  38:     if story_input.get(\"source_bank_id\") != bank_id:\r\n  39:         raise SourceInterpreterError(\r\n  40:             f\"bridge story_input bank {story_input.get('source_bank_id')!r} \"\r\n  41:             f\"!= requested bank {bank_id!r} - refusing cross-lane input\"\r\n  42:         )\r\n  43:     out: dict[str, Any] = {}\r\n  44:     for field in LOGICAL_FIELDS:\r\n  45:         value = story_input.get(field)\r\n  46:         if field == \"key_terms\":\r\n  47:             if not isinstance(value, list):\r\n  48:                 raise SourceInterpreterError(\r\n  49:                     f\"{bank_id}: story_input.key_terms must be a list\"\r\n  50:                 )\r\n  51:             out[field] = list(value)\r\n  52:         else:\r\n  53:             if not str(value or \"\").strip():\r\n  54:                 raise SourceInterpreterError(\r\n  55:                     f\"{bank_id}: story_input.{field} is required and empty \"\r\n  56:                     \"(the lab authors this content in JSON; nothing is invented here)\"\r\n  57:                 )\r\n  58:             out[field] = str(value)\r\n  59:     return out\r\n  60: \r\n  61: \r\n  62: def interpret_source(\r\n  63:     bank_id: str,\r\n  64:     *,\r\n  65:     article: dict[str, Any] | None = None,\r\n  66:     bridge_story_input: dict[str, Any] | None = None,\r\n  67:     news_briefs_builder: Callable[..., Any] | None = None,\r\n  68:     **builder_kwargs: Any,\r\n  69: ) -> dict[str, Any]:\r\n  70:     bank = (bank_id or \"\").strip()\r\n  71:     if bank == \"science_news\":\r\n  72:         if news_briefs_builder is None:\r\n  73:             raise SourceInterpreterError(\r\n  74:                 \"science_news requires news_briefs_builder \"\r\n  75:                 \"(wire news_interpreter.build_news_briefs); the facade never \"\r\n  76:                 \"re-implements the science brain\"\r\n  77:             )\r\n  78:         briefs = news_briefs_builder(article=article, **builder_kwargs)\r\n  79:         data = briefs.model_dump() if hasattr(briefs, \"model_dump\") else dict(briefs)\r\n  80:         return {\r\n  81:             \"casting_brief\": data[\"casting_brief\"],\r\n  82:             \"script_brief\": data[\"script_brief\"],\r\n  83:             \"close_brief\": data[\"news_close_brief\"],\r\n  84:             \"key_terms\": list(data[\"key_terms\"]),\r\n  85:         }\r\n  86:     if bank in PACKET_DRIVEN_BANKS:\r\n  87:         if bridge_story_input is None:\r\n  88:             raise SourceInterpreterError(\r\n  89:                 f\"{bank} is packet-driven in v1 and requires bridge_story_input \"\r\n  90:                 \"(a validated bridge artifact's story_input block); there is no \"\r\n  91:                 \"live fetcher for this lane yet and no fallback to science RSS\"\r\n  92:             )\r\n  93:         return _from_bridge_story_input(bank, bridge_story_input)\r\n  94:     if bank == \"custom_source_bank\":\r\n  95:         raise SourceInterpreterError(\r\n  96:             \"custom_source_bank is visible but not runnable: create and \"\r\n  97:             \"validate a custom schema, source packet, and story pack first \"\r\n  98:             \"(see upstream lab CUSTOM_SOURCE_BANK_GUIDE.md)\"\r\n  99:         )\r\n 100:     raise SourceInterpreterError(f\"unknown source bank {bank!r}\")\r\n","exit_code":0,"status":"completed"}}
