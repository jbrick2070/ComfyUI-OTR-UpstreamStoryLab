{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=1; Get-Content -LiteralPath '\"'tests\\\\test_compat_drift.py' | ForEach-Object { '{0,4}: {1}' -f \"'$i++, $_ }'","aggregated_output":"   1: \"\"\"AST drift-proofing: pinned production shapes vs production_mirror.\r\n   2: \r\n   3: Never imports mirrored modules (the mirror is dependency-incomplete by\r\n   4: design). When production moves and the mirror is refreshed, these fail with\r\n   5: re-pin messages instead of letting the bridge rot silently.\r\n   6: \"\"\"\r\n   7: \r\n   8: from __future__ import annotations\r\n   9: \r\n  10: import pytest\r\n  11: \r\n  12: from upstream_story_lab.compat import (\r\n  13:     MOTION_ROLE_KEYS,\r\n  14:     NEWS_BRIEFS_FIELDS,\r\n  15:     NEWS_SEED_KEYS,\r\n  16:     NEWS_SEED_REQUIRED_KEYS,\r\n  17:     CompatDriftError,\r\n  18:     PRODUCTION_VISUAL_TAILS,\r\n  19:     canonical_json_hash,\r\n  20:     extract_motion_role_keys,\r\n  21:     extract_news_briefs_fields,\r\n  22:     extract_news_seed_keys,\r\n  23:     extract_visual_tails,\r\n  24: )\r\n  25: \r\n  26: \r\n  27: def test_news_briefs_fields_match_mirror(mirror_nodes) -> None:\r\n  28:     extracted = extract_news_briefs_fields(mirror_nodes / \"news_interpreter.py\")\r\n  29:     assert tuple(extracted) == NEWS_BRIEFS_FIELDS, (\r\n  30:         \"NewsBriefs drifted - re-verify meta.news mirror and re-pin compat.py\"\r\n  31:     )\r\n  32: \r\n  33: \r\n  34: def test_news_seed_keys_match_mirror(mirror_nodes) -> None:\r\n  35:     extracted = extract_news_seed_keys(\r\n  36:         mirror_nodes / \"_otr_legacy_to_stage1_adapter.py\"\r\n  37:     )\r\n  38:     assert tuple(extracted) == NEWS_SEED_KEYS\r\n  39:     assert set(NEWS_SEED_REQUIRED_KEYS).issubset(extracted)\r\n  40: \r\n  41: \r\n  42: def test_motion_role_keys_match_mirror(mirror_nodes) -> None:\r\n  43:     extracted = extract_motion_role_keys(\r\n  44:         mirror_nodes / \"_otr_video_engines\" / \"render_driver.py\"\r\n  45:     )\r\n  46:     assert tuple(extracted) == MOTION_ROLE_KEYS\r\n  47:     dead = {\"sfx\", \"scene_broll\", \"background_abstract\"}\r\n  48:     assert not dead.intersection(extracted), \"a dead role came back\"\r\n  49: \r\n  50: \r\n  51: def test_visual_tails_match_mirror_byte_identically(mirror_nodes) -> None:\r\n  52:     extracted = extract_visual_tails(mirror_nodes / \"_otr_story_brief_helpers.py\")\r\n  53:     assert extracted == PRODUCTION_VISUAL_TAILS\r\n  54: \r\n  55: \r\n  56: def test_extractors_fail_pointedly_on_missing_mirror(tmp_path) -> None:\r\n  57:     with pytest.raises(CompatDriftError, match=\"mirror file missing\"):\r\n  58:         extract_news_briefs_fields(tmp_path / \"nope.py\")\r\n  59: \r\n  60: \r\n  61: def test_canonical_hash_ignores_whitespace_and_order() -> None:\r\n  62:     a = {\"b\": 1, \"a\": [1, 2]}\r\n  63:     b = {\"a\": [1, 2], \"b\": 1}\r\n  64:     assert canonical_json_hash(a) == canonical_json_hash(b)\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=1; Get-Content -LiteralPath '\"'src\\\\upstream_story_lab\\\\compat.py' | ForEach-Object { '{0,4}: {1}' -f \"'$i++, $_ }'","aggregated_output":"   1: \"\"\"Pinned production compatibility shapes + AST drift-proofing.\r\n   2: \r\n   3: Every pin cites its production_mirror source. Drift tests EXTRACT the same\r\n   4: shape from the mirrored file by AST (never by importing it - the mirror is\r\n   5: deliberately dependency-incomplete) and compare against the pin. When\r\n   6: production moves and the mirror is refreshed, any shape change fails a test\r\n   7: with a pointed re-pin message instead of silently rotting.\r\n   8: \"\"\"\r\n   9: \r\n  10: from __future__ import annotations\r\n  11: \r\n  12: import ast\r\n  13: import hashlib\r\n  14: import json\r\n  15: import re\r\n  16: from pathlib import Path\r\n  17: from typing import Any\r\n  18: \r\n  19: #: meta.news == NewsBriefs.model_dump() - all 13 fields, exactly.\r\n  20: #: Source: production_mirror/nodes/news_interpreter.py (class NewsBriefs).\r\n  21: NEWS_BRIEFS_FIELDS = (\r\n  22:     \"casting_brief\",\r\n  23:     \"script_brief\",\r\n  24:     \"news_close_brief\",\r\n  25:     \"key_terms\",\r\n  26:     \"source_hash\",\r\n  27:     \"source_chars\",\r\n  28:     \"prompt_version\",\r\n  29:     \"schema_version\",\r\n  30:     \"model_id\",\r\n  31:     \"decoder_profile\",\r\n  32:     \"seed\",\r\n  33:     \"attempts\",\r\n  34:     \"attempt_failures\",\r\n  35: )\r\n  36: \r\n  37: #: meta.news_seed dict keys (current ledger shape).\r\n  38: #: Source: production_mirror/nodes/_otr_legacy_to_stage1_adapter.py\r\n  39: #: (_coerce_news_seed_text docstring). REQUIRED subset = the keys the\r\n  40: #: adapter actually reads; the rest are optional for mirror emission.\r\n  41: NEWS_SEED_KEYS = (\r\n  42:     \"headline\",\r\n  43:     \"source\",\r\n  44:     \"url\",\r\n  45:     \"date\",\r\n  46:     \"body_chars\",\r\n  47:     \"style\",\r\n  48:     \"selected_at\",\r\n  49: )\r\n  50: NEWS_SEED_REQUIRED_KEYS = (\"headline\", \"source\")\r\n  51: \r\n  52: #: news_article dict keys (writer fetch return / news_used socket shape).\r\n  53: #: Source: production_mirror/nodes/OTR_LedgerScriptWriter.py\r\n  54: #: (_fetch_rss_seed_or_die docstring return-shape contract).\r\n  55: NEWS_ARTICLE_KEYS = (\r\n  56:     \"headline\",\r\n  57:     \"summary\",\r\n  58:     \"full_text\",\r\n  59:     \"source\",\r\n  60:     \"date\",\r\n  61:     \"link\",\r\n  62:     \"seed_text\",\r\n  63: )\r\n  64: \r\n  65: #: Production motion-prompt role vocabulary.\r\n  66: #: Source: production_mirror/nodes/_otr_video_engines/render_driver.py\r\n  67: #: (_LTX_MOTION_PROMPT_BY_ROLE keys).\r\n  68: MOTION_ROLE_KEYS = (\"announcer\", \"music_open\", \"music_close\", \"music_inter\")\r\n  69: \r\n  70: #: Genre-neutral production visual tail constants (NOT sci-fi-specific; the\r\n  71: #: sci_fi_radio policy must REPRODUCE them byte-identically).\r\n  72: #: Source: production_mirror/nodes/_otr_story_brief_helpers.py.\r\n  73: PRODUCTION_VISUAL_TAILS = {\r\n  74:     \"ERA_TAIL_DEFAULT\": \"timeless cinematic aesthetic\",\r\n  75:     \"STYLE_TAIL_DEFAULT\": (\r\n  76:         \"cinematic, 35mm film look, subtle film grain, volumetric lighting\"\r\n  77:     ),\r\n  78:     \"IMAGE_GRADE_TAIL\": (\r\n  79:         \"anamorphic lens, heavy vignette, muted color grade, sharp focus\"\r\n  80:     ),\r\n  81:     \"RADIO_BROADCAST_TAIL\": (\r\n  82:         \"35mm film grain, broadcast-distressed cinematic aesthetic, \"\r\n  83:         \"centered composition\"\r\n  84:     ),\r\n  85: }\r\n  86: \r\n  87: \r\n  88: class CompatDriftError(AssertionError):\r\n  89:     \"\"\"A pinned production shape no longer matches the mirror. Re-verify the\r\n  90:     shape against the refreshed production_mirror and re-pin compat.py.\"\"\"\r\n  91: \r\n  92: \r\n  93: def canonical_json_hash(data: Any) -> str:\r\n  94:     \"\"\"sha256 over canonical JSON (sort_keys, tight separators). Whitespace\r\n  95:     and key order never change the hash (kibitz r1 optional, accepted).\"\"\"\r\n  96: \r\n  97:     payload = json.dumps(data, sort_keys=True, separators=(\",\", \":\"), ensure_ascii=False)\r\n  98:     return hashlib.sha256(payload.encode(\"utf-8\")).hexdigest()\r\n  99: \r\n 100: \r\n 101: def file_sha256(path: Path) -> str:\r\n 102:     return hashlib.sha256(path.read_bytes()).hexdigest()\r\n 103: \r\n 104: \r\n 105: def _parse(path: Path) -> ast.Module:\r\n 106:     if not path.exists():\r\n 107:         raise CompatDriftError(\r\n 108:             f\"mirror file missing: {path} - refresh production_mirror before \"\r\n 109:             \"running drift checks\"\r\n 110:         )\r\n 111:     return ast.parse(path.read_text(encoding=\"utf-8\"))\r\n 112: \r\n 113: \r\n 114: def extract_news_briefs_fields(news_interpreter_py: Path) -> list[str]:\r\n 115:     \"\"\"AST-extract NewsBriefs annotated field names (order preserved).\"\"\"\r\n 116: \r\n 117:     tree = _parse(news_interpreter_py)\r\n 118:     for node in ast.walk(tree):\r\n 119:         if isinstance(node, ast.ClassDef) and node.name == \"NewsBriefs\":\r\n 120:             fields = [\r\n 121:                 stmt.target.id\r\n 122:                 for stmt in node.body\r\n 123:                 if isinstance(stmt, ast.AnnAssign) and isinstance(stmt.target, ast.Name)\r\n 124:             ]\r\n 125:             if not fields:\r\n 126:                 raise CompatDriftError(\r\n 127:                     \"NewsBriefs class found but no annotated fields extracted - \"\r\n 128:                     \"re-pin NEWS_BRIEFS_FIELDS against the mirror\"\r\n 129:                 )\r\n 130:             return fields\r\n 131:     raise CompatDriftError(\r\n 132:         f\"class NewsBriefs not found in {news_interpreter_py} - re-pin against \"\r\n 133:         \"the refreshed mirror\"\r\n 134:     )\r\n 135: \r\n 136: \r\n 137: def extract_news_seed_keys(adapter_py: Path) -> list[str]:\r\n 138:     \"\"\"Extract the documented news_seed dict keys from the adapter docstring.\r\n 139: \r\n 140:     The shape lives in prose (a docstring contract), so this is a regex over\r\n 141:     the documented dict literal, not code AST - still read-only, never an\r\n 142:     import.\"\"\"\r\n 143: \r\n 144:     text = adapter_py.read_text(encoding=\"utf-8\") if adapter_py.exists() else \"\"\r\n 145:     if not text:\r\n 146:         raise CompatDriftError(f\"mirror file missing or empty: {adapter_py}\")\r\n 147:     match = re.search(r\"meta\\.news_seed\\s*=\\s*\\{(.*?)\\}\", text, flags=re.DOTALL)\r\n 148:     if not match:\r\n 149:         raise CompatDriftError(\r\n 150:             \"documented news_seed dict not found in adapter docstring - re-pin \"\r\n 151:             \"NEWS_SEED_KEYS against the refreshed mirror\"\r\n 152:         )\r\n 153:     keys = re.findall(r'\"([a-z_]+)\"\\s*:', match.group(1))\r\n 154:     if not keys:\r\n 155:         raise CompatDriftError(\"news_seed docstring matched but no keys parsed\")\r\n 156:     return keys\r\n 157: \r\n 158: \r\n 159: def extract_motion_role_keys(render_driver_py: Path) -> list[str]:\r\n 160:     \"\"\"AST-extract _LTX_MOTION_PROMPT_BY_ROLE key strings.\"\"\"\r\n 161: \r\n 162:     tree = _parse(render_driver_py)\r\n 163:     for node in ast.walk(tree):\r\n 164:         if isinstance(node, ast.Assign):\r\n 165:             targets = [t.id for t in node.targets if isinstance(t, ast.Name)]\r\n 166:             if \"_LTX_MOTION_PROMPT_BY_ROLE\" in targets and isinstance(\r\n 167:                 node.value, ast.Dict\r\n 168:             ):\r\n 169:                 keys = [\r\n 170:                     k.value\r\n 171:                     for k in node.value.keys\r\n 172:                     if isinstance(k, ast.Constant) and isinstance(k.value, str)\r\n 173:                 ]\r\n 174:                 if not keys:\r\n 175:                     raise CompatDriftError(\r\n 176:                         \"_LTX_MOTION_PROMPT_BY_ROLE found but empty - re-pin\"\r\n 177:                     )\r\n 178:                 return keys\r\n 179:     raise CompatDriftError(\r\n 180:         f\"_LTX_MOTION_PROMPT_BY_ROLE not found in {render_driver_py} - re-pin \"\r\n 181:         \"MOTION_ROLE_KEYS against the refreshed mirror\"\r\n 182:     )\r\n 183: \r\n 184: \r\n 185: def extract_visual_tails(brief_helpers_py: Path) -> dict[str, str]:\r\n 186:     \"\"\"AST-extract the four production tail constants (string concatenations\r\n 187:     folded).\"\"\"\r\n 188: \r\n 189:     tree = _parse(brief_helpers_py)\r\n 190:     wanted = set(PRODUCTION_VISUAL_TAILS)\r\n 191:     out: dict[str, str] = {}\r\n 192:     for node in ast.walk(tree):\r\n 193:         if isinstance(node, ast.Assign):\r\n 194:             for target in node.targets:\r\n 195:                 if isinstance(target, ast.Name) and target.id in wanted:\r\n 196:                     try:\r\n 197:                         value = ast.literal_eval(node.value)\r\n 198:                     except (ValueError, SyntaxError) as exc:\r\n 199:                         raise CompatDriftError(\r\n 200:                             f\"{target.id} is no longer a literal string - re-pin\"\r\n 201:                         ) from exc\r\n 202:                     if isinstance(value, str):\r\n 203:                         out[target.id] = value\r\n 204:     missing = sorted(wanted - set(out))\r\n 205:     if missing:\r\n 206:         raise CompatDriftError(\r\n 207:             f\"tail constants not found in mirror: {missing} - re-pin \"\r\n 208:             \"PRODUCTION_VISUAL_TAILS against the refreshed mirror\"\r\n 209:         )\r\n 210:     return out\r\n","exit_code":0,"status":"completed"}}
