aseline hash - mirror FILE\r\n  45:     contents are a validation-time concern covered by the drift tests and\r\n  46:     the ComfyUI digest, intentionally not re-hashed here).\"\"\"\r\n  47: \r\n  48:     manifest = Path(root) / \"PRODUCTION_MIRROR_MANIFEST.md\"\r\n  49:     if not manifest.exists():\r\n  50:         raise BridgeError(\r\n  51:             f\"PRODUCTION_MIRROR_MANIFEST.md missing at {manifest} - cannot \"\r\n  52:             \"stamp production_baseline provenance\"\r\n  53:         )\r\n  54:     match = re.search(r\"commit\\s+([0-9a-f]{40})\", manifest.read_text(encoding=\"utf-8\"))\r\n  55:     if not match:\r\n  56:         raise BridgeError(\r\n  57:             \"no production commit hash found in PRODUCTION_MIRROR_MANIFEST.md\"\r\n  58:         )\r\n  59:     return match.group(1)\r\n  60: \r\n  61: \r\n  62: def build_spec(registry: Registry, *, source_bank_id: str,\r\n  63:                story_model_id: str = \"auto\", story_pipeline_id: str = \"auto\",\r\n  64:                visual_style_id: str = \"auto\",\r\n  65:                packet: SourceMaterialPacket | None = None,\r\n  66:                production_baseline: str = \"\") -> LedgerWritingSpec:\r\n  67:     \"\"\"Resolve ids, interpret source, and assemble a cross-validated spec.\"\"\"\r\n  68: \r\n  69:     resolution = registry.resolve(\r\n  70:         source_bank_id=source_bank_id,\r\n  71:         story_model_id=story_model_id,\r\n  72:         story_pipeline_id=story_pipeline_id,\r\n  73:         visual_style_id=visual_style_id,\r\n  74:     )\r\n  75:     bank_id = resolution.resolved(\"source_bank\")\r\n  76:     model_id = resolution.resolved(\"story_model\")\r\n  77:     pipeline_id = resolution.resolved(\"story_pipeline\")\r\n  78:     style_id = resolution.resolved(\"visual_style\")\r\n  79: \r\n  80:     bank = registry.bank(bank_id)\r\n  81:     if packet is None:\r\n  82:         packet, packet_path = registry.source_packet(bank_id)\r\n  83:     else:\r\n  84:    