ane\"):\r\n 107:         facade.interpret_source(\"public_domain_story\", bridge_story_input=story_input)\r\n 108: \r\n 109: \r\n 110: def test_facade_science_wraps_builder_verbatim() -> None:\r\n 111:     class FakeBriefs:\r\n 112:         def model_dump(self):\r\n 113:             return {\r\n 114:                 \"casting_brief\": \"c\", \"script_brief\": \"s\",\r\n 115:                 \"news_close_brief\": \"n\", \"key_terms\": [\"k\"],\r\n 116:             }\r\n 117: \r\n 118:     calls = {}\r\n 119: \r\n 120:     def builder(article=None, **kwargs):\r\n 121:         calls[\"article\"] = article\r\n 122:         return FakeBriefs()\r\n 123: \r\n 124:     out = facade.interpret_source(\r\n 125:         \"science_news\", article={\"headline\": \"h\"}, news_briefs_builder=builder,\r\n 126:     )\r\n 127:     assert out[\"close_brief\"] == \"n\"\r\n 128:     assert calls[\"article\"] == {\"headline\": \"h\"}\r\n","exit_code":0,"status":"completed"}}
