{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$p='\"'production_mirror\\\\nodes\\\\_otr_legacy_to_stage1_adapter.py'; \"'$i=1; Get-Content -LiteralPath $p | ForEach-Object { if($i -ge 60 -and $i -le 115){ '\"'{0}:{1}' -f \"'$i, $_ }; $i++ }'","aggregated_output":"60:\r\n61:# ---------------------------------------------------------------------------\r\n62:# Helpers\r\n63:# ---------------------------------------------------------------------------\r\n64:\r\n65:\r\n66:def _coerce_news_seed_text(raw: Any) -> str:\r\n67:    \"\"\"Coerce meta.news_seed (which is a dict in current ledgers and was a\r\n68:    plain string in older ones) to a text excerpt the adapter can use as\r\n69:    a premise placeholder.\r\n70:\r\n71:    Current ledger shape (post-Sprint-10A NewsFetcher refactor):\r\n72:        meta.news_seed = {\r\n73:            \"headline\": str, \"source\": str, \"url\": str,\r\n74:            \"date\": str,     \"body_chars\": int, \"style\": str,\r\n75:            \"selected_at\": str\r\n76:        }\r\n77:    Older / handwritten ledgers may carry meta.news_seed as a single\r\n78:    string (the full body excerpt). We accept either shape.\r\n79:\r\n80:    BUG-LOCAL-277 (2026-05-26): the live soak run\r\n81:    signal_lost_..._154105 surfaced an AttributeError on the dict shape\r\n82:    because the adapter did `(meta.get('news_seed') or '').strip()`,\r\n83:    assuming the field was always a string. Fix: coerce centrally with\r\n84:    type-aware logic and let `.strip()` see real strings only.\r\n85:\r\n86:    Args:\r\n87:        raw: whatever lives at meta.news_seed -- str, dict, None,\r\n88:             or something unexpected.\r\n89:\r\n90:    Returns:\r\n91:        Best-effort text excerpt, possibly empty. Never raises.\r\n92:    \"\"\"\r\n93:    if isinstance(raw, str):\r\n94:        return raw.strip()\r\n95:    if isinstance(raw, dict):\r\n96:        # Prefer the headline; fall back to source as a last resort so\r\n97:        # the critic at least sees a topic anchor.\r\n98:        headline = raw.get(\"headline\")\r\n99:        if isinstance(headline, str) and headline.strip():\r\n100:            return headline.strip()\r\n101:        source = raw.get(\"source\")\r\n102:        if isinstance(source, str) and source.strip():\r\n103:            return source.strip()\r\n104:    return \"\"\r\n105:\r\n106:\r\n107:def _gender_to_pronouns(gender: str) -> str:\r\n108:    \"\"\"Map cast_pools gender literal -> Stage 1 pronouns literal.\"\"\"\r\n109:    g = (gender or \"\").strip().lower()\r\n110:    if g == \"female\":\r\n111:        return \"she/her\"\r\n112:    if g == \"nonbinary\":\r\n113:        return \"they/them\"\r\n114:    return \"he/him\"   # default for 'male' AND for unknown / empty\r\n115:\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$p='\"'production_mirror\\\\nodes\\\\_otr_video_engines\\\\render_driver.py'; \"'$i=1; Get-Content -LiteralPath $p | ForEach-Object { if($i -ge 540 -and $i -le 565){ '\"'{0}:{1}' -f \"'$i, $_ }; $i++ }'","aggregated_output":"540:#: from the FLUX still; the video prompt's ONLY job is MOTION. Design rules\r\n541:#: (MAD-verified): every sentence is a motion verb, NO set-dressing nouns, NO\r\n542:#: negation, total <= 240 chars, first motion verb within the first 140. The\r\n543:#: refactor had diluted these into ~185-char scene-DESCRIPTIVE \"brief+beat\"\r\n544:#: prompts (\"a 1940s radio station studio, glowing warmly...\"), which the model\r\n545:#: reads as \"render this set\" -> flat pans on the conditioned still.\r\n546:_LTX_MOTION_PROMPT_BY_ROLE = {\r\n547:    \"announcer\": (\"Continuous shot, same console throughout. Tuning dial needle \"\r\n548:                  \"sweeps rhythmically. Vacuum tubes pulse. Brass speaker grille \"\r\n549:                  \"trembles. Dust motes drift. Slow handheld dolly forward.\"),\r\n550:    \"music_open\": (\"Continuous shot, same console throughout. Dial whip-pans \"\r\n551:                   \"across frequencies. Tube filaments ignite from cold to \"\r\n552:                   \"white-hot. Speaker grille vibrates aggressively. Dynamic \"\r\n553:                   \"dolly push forward.\"),\r\n554:    \"music_close\": (\"Continuous shot, same console throughout. Dial settles. \"\r\n555:                    \"Tube filaments cool from white through deep amber. Smoke \"\r\n556:                    \"trails from cooling tubes. Slow dolly pull back.\"),\r\n557:    \"music_inter\": (\"Continuous shot, same console throughout. Dial steady, \"\r\n558:                    \"glowing. Oscilloscope dances to the rhythm. VU meters \"\r\n559:                    \"bounce. Tubes pulse with the bass. Slow orbit around the \"\r\n560:                    \"speaker.\"),\r\n561:}\r\n562:#: BUG-LOCAL-112 char budget for the motion prompt (verb-only core + optional\r\n563:#: short brief fragment appended AFTER, dropped if it breaks the budget).\r\n564:_LTX_MOTION_PROMPT_MAX = 240\r\n565:\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$p='\"'production_mirror\\\\nodes\\\\OTR_LedgerScriptWriter.py'; \"'$i=1; Get-Content -LiteralPath $p | ForEach-Object { if(($i -ge 1119 -and $i -le 1145) -or ($i -ge 1374 -and $i -le 1405) -or ($i -ge 2878 -and $i -le 2895) -or ($i -ge 5428 -and $i -le 5455)){ '\"'{0}:{1}' -f \"'$i, $_ }; $i++ }'","aggregated_output":"1119:def _fetch_rss_seed_or_die(style: str, model_id: str) -> dict:\r\n1120:    \"\"\"Run the story_orchestrator RSS fetcher and return the article dict.\r\n1121:\r\n1122:    Lifts the exact path the legacy writer used. `style` is mapped to\r\n1123:    the closest legacy slug for the LLM re-rank step; if the fetcher\r\n1124:    returns None (every feed failed) we raise loudly -- the legacy\r\n1125:    writer behaved the same.\r\n1126:\r\n1127:    Return shape (commit 3 of the news_interpreter sprint, ADR\r\n1128:    docs/news_interpreter_adr.md section 9.1): a dict with keys\r\n1129:    ``headline``, ``summary``, ``full_text``, ``source``, ``date``,\r\n1130:    ``link``, plus a computed ``seed_text`` for back-compat with\r\n1131:    consumers that still treat news_seed as a plain string. Previously\r\n1132:    this function returned only the seed_text string; the richer\r\n1133:    return lets the news_interpreter stage read the full body that\r\n1134:    the cast LLM never sees today.\r\n1135:    \"\"\"\r\n1136:    try:\r\n1137:        try:\r\n1138:            from . import story_orchestrator as _so\r\n1139:        except ImportError:\r\n1140:            import story_orchestrator as _so  # type: ignore\r\n1141:        # Style normalization: re-ranker expects a slug like \"hard_sci_fi\";\r\n1142:        # use the closest match or fall back to the canonical default.\r\n1143:        slug = (style or \"\").lower().replace(\" \", \"_\").replace(\"-\", \"_\")\r\n1144:        if slug not in {\r\n1145:            \"closed_room_suspense\",\r\n1374:    return {\r\n1375:        \"news_seed\":            news_seed,\r\n1376:        \"news_article\":         news_article,\r\n1377:        \"seed_source\":          seed_source,\r\n1378:        \"style\":                resolved_style,\r\n1379:        \"style_source\":         style_source,\r\n1380:        \"style_pending\":        style_pending,\r\n1381:        \"style_combo\":          style_combo,\r\n1382:        \"style_custom\":         sc,\r\n1383:        \"target_words\":         target_words,\r\n1384:        \"num_characters\":       num_characters,\r\n1385:        \"episode_title\":        (episode_title or \"\").strip(),\r\n1386:        # S30 B2b: per-slot keys ONLY. The legacy `model_id` key is\r\n1387:        # deleted outright; consumers route via creative_writing_model\r\n1388:        # / technical_model. No \"stamp both\" hedge.\r\n1389:        \"creative_writing_model\": creative_writing_model,\r\n1390:        \"technical_model\":        technical_model,\r\n1391:        \"include_act_breaks\":   bool(include_act_breaks),\r\n1392:        \"act_count\":            int(act_count_int),\r\n1393:        \"creativity\":           str(creativity),\r\n1394:        \"temperature\":          float(temperature),\r\n1395:        \"top_p\":                float(top_p),\r\n1396:        \"optimization_profile\": str(optimization_profile),\r\n1397:        \"perfect_run_spacesaver\": bool(perfect_run_spacesaver),\r\n1398:        # Phase 4 v4 (2026-05-11) sampling knobs. Clamped to widget\r\n1399:        # ranges so a hand-edited workflow JSON can't slip through\r\n1400:        # out-of-band values.\r\n1401:        \"min_p\":                max(0.0, min(0.5, float(min_p or 0.0))),\r\n1402:        \"repetition_penalty\":   max(1.0, min(1.2, float(\r\n1403:            repetition_penalty or 1.0,\r\n1404:        ))),\r\n1405:        \"max_new_tokens_cap\":   max(40, min(400, int(\r\n2878:                    outlet=article.get(\"source\", \"\"),\r\n2879:                    pub_date=article.get(\"date\", \"\"),\r\n2880:                    style=resolved[\"style\"],\r\n2881:                    # The `seed` widget was removed (BUG-LOCAL-269/270\r\n2882:                    # follow-up); a constant keeps the news-interpreter\r\n2883:                    # cache key stable across the seed dimension.\r\n2884:                    seed=0,\r\n2885:                    model_id=str(resolved[\"technical_model\"]),\r\n2886:                )\r\n2887:            meta[\"news\"] = briefs.model_dump()\r\n2888:            casting_brief = briefs.casting_brief\r\n2889:            script_brief = briefs.script_brief\r\n2890:            key_terms_tuple: tuple[str, ...] = tuple(briefs.key_terms)\r\n2891:            log.info(\r\n2892:                \"[OTR_LedgerScriptWriter] news_interpreter OK: \"\r\n2893:                \"%d key_terms in %d attempt(s)\",\r\n2894:                len(briefs.key_terms), briefs.attempts,\r\n2895:            )\r\n5428:        # the loader is single-slot by architecture. request_slot(\r\n5429:        # technical_model) inside technical_generate_fn calls\r\n5430:        # unload_llm() to evict any prior resident model BEFORE loading\r\n5431:        # the next. Peak transient VRAM during the swap is max(\r\n5432:        # creative_size, technical_size), not their sum. No explicit\r\n5433:        # pre-eviction call is needed; regression tests in C5a2 prove\r\n5434:        # the no-OOM property.\r\n5435:        # LLM slot: technical\r\n5436:        # Sprint 0 (v4 plan): helper_context attribution.\r\n5437:        with slot_scheduler.helper_context(\"story_brief_reflection\"):\r\n5438:            _brief_delta = run_story_brief_reflection(\r\n5439:                led,\r\n5440:                technical_generate_fn,\r\n5441:                technical_model_id=resolved[\"technical_model\"],\r\n5442:            )\r\n5443:        meta.update(_brief_delta)\r\n5444:\r\n5445:        # --- Story-spine Wave 2: the post-script passes (Stage 2.5 length\r\n5446:        # pass / Stage 3 QA router / Stage 3.5 micro-repair / unload /\r\n5447:        # Stage 4 scrub), in-process + env-gated, DEFAULT ON (opt-out). The\r\n5448:        # orchestrator runs them out of the box; OTR_ENABLE_STORY_SPINE=0\r\n5449:        # restores the writer's byte-identical default path (the unload\r\n5450:        # block in the else branch). When on, the orchestrator performs the\r\n5451:        # writer-LLM unload itself, after the LLM passes (D8). The spine\r\n5452:        # NEVER raises (PD1); the only fail-loud signal is the REJECT gate\r\n5453:        # checked right after this block. No node surface, no workflow-JSON\r\n5454:        # change (D4/D5); model ids come from resolved[...] (QA -> technical\r\n5455:        # slot, length pass + micro-repair -> creative slot).\r\n","exit_code":0,"status":"completed"}}
