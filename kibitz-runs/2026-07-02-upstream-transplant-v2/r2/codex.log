:1. Prefer specific dramatic situations over generic genre tags.\r\n339:2. Prefer auditory or signal-based grounding (signal, broadcast, log, frequency, archive).\r\n340:3. Match the article's actual stakes, not surface vibes.\r\n341:\r\n342:Output only the chosen descriptor. No explanation.\r\n343:\r\n344:ARTICLE:\r\n345:<<<\r\n720:    cosmetic style-slug pick must NEVER halt the whole episode, so on a\r\n721:    bad LLM call or an invalid pick we retry, and after `max_attempts`\r\n722:    fall back to the first candidate instead of raising. Validation still\r\n723:    rejects the hallucinated slug -- we recover rather than crash.\r\n724:    \"\"\"\r\n725:    user_prompt = _build_chooser_user_prompt(article_excerpt, candidates)\r\n726:    messages = [\r\n727:        {\"role\": \"system\", \"content\": _CHOOSER_SYSTEM},\r\n728:        {\"role\": \"user\",   \"content\": user_prompt},\r\n729:    ]\r\n730:\r\n731:    last_err = \"\"\r\n732:    for attempt_idx in range(max_attempts):\r\n733:        log.info(\r\n734:            \"[OTR_StylePicker] chooser attempt %d/%d (temp=%.2f)\",\r\n735:            attempt_idx + 1, max_attempts, _CHOOSER_TEMPERATURE,\r\n736:        )\r\n737:        try:\r\n738:            # LLM slot: technical -- chooser pass (single-index pick)\r\n739:            raw = generate_fn(\r\n740:                messages,\r\n741:                temperature=float(_CHOOSER_TEMPERATURE),\r\n742:                max_new_tokens=_CHOOSER_MAX_TOKENS,\r\n743:            )\r\n744:        except Exception as exc:  # noqa: BLE001\r\n745:            last_err = f\"generate_fn raised: {type(exc).__name__}: {exc}\"\r\n746:            log.warning(\r\n747:                \"[OTR_StylePicker] chooser attempt %d/%d: %s\",\r\n748:                attempt_idx + 1, max_attempts, last_err,\r\n749:            )\r\n750:            continue\r\n751:\r\n752:        try:\r\n753:            chosen = _validate_chooser_output(raw, candidates)\r\n754:        except ValueError as exc:\r\n755:            last_err = str(exc)\r\n756:            log.warning(\r\n757:                \"[OTR_StylePicker] chooser attempt %d/%d rejected: %s\",\r\n758:                attempt_idx + 1, max_attempts, last_err,\r\n759:            )\r\n760:            continue\r\n761:\r\n762:        log.info(\r\n763:            \"[OTR_StylePicker] chooser picked %r (attempt %d/%d)\",\r\n764:            chosen, attempt_idx + 1, max_attempts,\r\n765:        )\r\n766:        return chosen\r\n767:\r\n768:    fallback = candidates[0]\r\n769:    log.warning(\r\n770:        \"[OTR_StylePicker] chooser failed %d attempt(s) (last: %s); \"\r\n","exit_code":0,"status":"completed"}}
