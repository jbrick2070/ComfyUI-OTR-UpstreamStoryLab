n1896:                        \"overrides the style combo above AND disables \"\r\n1897:                        \"the LLM 'auto' path. Examples: 'rust-belt \"\r\n1898:                        \"cyber-noir', 'pulp adventure with comic \"\r\n1899:                        \"timing', 'cosmic horror procedural'.\"\r\n1900:                    ),\r\n1901:                }),\r\n1902:                \"creativity\": (_CREATIVITY_CHOICES, {\r\n1903:                    \"default\": \"balanced\",\r\n1904:                    \"tooltip\": (\r\n1905:                        \"Creativity dial ƒ?\" overrides raw temperature \"\r\n2820:            _creative_slug = _creative_model\r\n2821:            if _creative_model.startswith(\"openrouter:\"):\r\n2822:                try:\r\n2823:                    from . import _otr_openrouter_backend as _orb_slug\r\n2824:                    _creative_slug = _orb_slug.resolve_slug(_creative_model)\r\n2825:                except Exception:  # noqa: BLE001 -- telemetry label only\r\n2826:                    _creative_slug = _creative_model\r\n2827:            with slot_scheduler.helper_context(\"pick_style\"):\r\n2828:                style_pick = _OTRSP.pick_style(\r\n2829:                    creative_fn=creative_generate_fn,\r\n2830:                    technical_fn=technical_generate_fn,\r\n2831:                    article_text=resolved[\"news_seed\"],\r\n2832:                    seed_pool=list(_STYLE_PICKER_SEED_POOL),\r\n2833:                    rng=picker_rng,\r\n2834:                    model_id=_creative_model,\r\n2835:                    model_slug=_creative_slug,\r\n2836:                )\r\n2837:            resolved[\"style\"] = style_pick.chosen\r\n2838:            meta[\"style_pick\"] = style_pick.model_dump()\r\n2839:            log.info(\r\n2840:                \"[OTR_LedgerScriptWriter] style picker: chosen=%r \"\r\n","exit_code":0,"status":"completed"}}
