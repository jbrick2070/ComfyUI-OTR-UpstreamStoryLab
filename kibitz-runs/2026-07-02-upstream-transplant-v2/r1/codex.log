poser.py:1537:            f\"line/section of dialogue for {req.speaker}. You are \r\n\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1538:            f\"responding to {req.prev_speaker}.\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1539:        )\r\n  production_mirror\\nodes\\_otr_line_composer.py:1541:        parts.append(\r\n  production_mirror\\nodes\\_otr_line_composer.py:1542:            f\"Here, you are now {req.speaker}. Produce one \"\r\n> production_mirror\\nodes\\_otr_line_composer.py:1543:            f\"line/section of dialogue for {req.speaker}.\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1544:        )\r\n> production_mirror\\nodes\\_otr_line_composer.py:1545:    # F4 (story-engine v1): pin the speaker's gender/pronouns so \r\nthe line\r\n> production_mirror\\nodes\\_otr_line_composer.py:1546:    # (and any in-line reference) never mis-genders or mis-titles \r\nthem.\r\n  production_mirror\\nodes\\_otr_line_composer.py:1547:    _pron = _gender_to_pronouns(req.speaker_gender)\r\n  production_mirror\\nodes\\_otr_line_composer.py:1548:    if _pron:\r\n  production_mirror\\nodes\\_otr_line_composer.py:1559:    # draft, the freeze cascade threads the critic's concrete \r\ninstruction\r\n  production_mirror\\nodes\\_otr_line_composer.py:1560:    # on `req.reroll_hint`. It renders as the last directive \r\nbefore\r\n> production_mirror\\nodes\\_otr_line_composer.py:1561:    # \"Speak now.\" so the rewrite instruction frames the line \r\nwith maximum\r\n  production_mirror\\nodes\\_otr_line_composer.py:1562:    # salience -- the model is fixing a flagged draft and the \r\nhint says\r\n  production_mirror\\nodes\\_otr_line_composer.py:1563:    # exactly how. Empty string -> block dropped (the normal \r\nfirst-pass\r\n  production_mirror\\nodes\\_otr_line_composer.py:1566:        parts.append(\"\")\r\n  production_mirror\\nodes\\_otr_line_composer.py:1567:        parts.append(\r\n> production_mirror\\nodes\\_otr_line_composer.py:1568:            \"REVISE: the previous draft of this line was flagged \r\nby the \"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1569:            \"story critic. Rewrite it to address this note \r\ndirectly:\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1570:        )\r\n  production_mirror\\nodes\\_otr_line_composer.py:1572:        parts.append(\"\")\r\n  production_mirror\\nodes\\_otr_line_composer.py:1573:    # Sprint 3 (2026-05-28): output constraint -- the \r\nanti-decorative\r\n> production_mirror\\nodes\\_otr_line_composer.py:1574:    # lever. Lands at the WRITE LINE tail (just above \"Speak \r\nnow.\")\r\n  production_mirror\\nodes\\_otr_line_composer.py:1575:    # so it is the model's last instruction. Conditional on any\r\n  production_mirror\\nodes\\_otr_line_composer.py:1576:    # Sprint 3 dramatic field being set; legacy callers (Sprint 2\r\n> production_mirror\\nodes\\_otr_line_composer.py:1577:    # Optional fields all empty) skip the constraint and the \r\nprompt\r\n  production_mirror\\nodes\\_otr_line_composer.py:1578:    # is byte-identical to pre-Sprint-3.\r\n  production_mirror\\nodes\\_otr_line_composer.py:1579:    # F6 (story-engine v1, SPLIT): the indirect-performance rider \r\nis now\r\n> production_mirror\\nodes\\_otr_line_composer.py:1580:    # UNCONDITIONAL on every character beat -- \"perform the line, \r\ndo not\r\n  production_mirror\\nodes\\_otr_line_composer.py:1581:    # narrate or summarize it\" is always-on craft, not a per-beat\r\n  production_mirror\\nodes\\_otr_line_composer.py:1582:    # decoration, so it no longer hangs off the Sprint-3 dramatic \r\nfields.\r\n  production_mirror\\nodes\\_otr_line_composer.py:1583:    # The situation-change clause stays GATED to turn/costly beats\r\n> production_mirror\\nodes\\_otr_line_composer.py:1584:    # (req.beat_turn present) so ordinary lines are not pushed to \r\nover-act\r\n  production_mirror\\nodes\\_otr_line_composer.py:1585:    # on every single beat (the over-acting risk the roundtable \r\nflagged).\r\n  production_mirror\\nodes\\_otr_line_composer.py:1586:    indirect = (\r\n> production_mirror\\nodes\\_otr_line_composer.py:1587:        \"Write 1 spoken line. Do not summarize the objective. \"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1588:        \"Do not explain the turn. Perform the objective \r\nindirectly. \"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1589:        \"Speak in the first person; never narrate your own \r\nactions in \"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1590:        \"the third person and never say your own name. \"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1591:        # D1 (2026-06-22, story-quality lift): the leak persists \r\nAFTER a closing \"\r\n> production_mirror\\nodes\\_otr_line_composer.py:1592:        # quote (\"...this.\" adjusts the dials) and mid-line. \r\nForbid every shape.\r\n  production_mirror\\nodes\\_otr_line_composer.py:1593:        \"Output ONLY the words the character says aloud -- no \r\nstage directions \"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1594:        \"anywhere: not before, not after, and not between \r\nquotation marks \"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1596:    )\r\n  production_mirror\\nodes\\_otr_line_composer.py:1597:    if req.beat_turn:\r\n> production_mirror\\nodes\\_otr_line_composer.py:1598:        indirect += \" The situation must be different after this \r\nline.\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:1599:    parts.append(indirect)\r\n> production_mirror\\nodes\\_otr_line_composer.py:1600:    # Story-spine Stream B1 (2026-05-31): universal \r\nnews-grounding +\r\n> production_mirror\\nodes\\_otr_line_composer.py:1601:    # one-breath length rider. Lands at the WRITE LINE tail (just \r\nabove\r\n  production_mirror\\nodes\\_otr_line_composer.py:1602:    # \"Speak now.\") so it is the model's last instruction, and \r\napplies\r\n> production_mirror\\nodes\\_otr_