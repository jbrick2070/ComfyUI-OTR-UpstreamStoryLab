roduction_mirror\\nodes\\_otr_line_composer.py:3007:    # bare trailing newline is not multi-line, so strip first.\r\n  production_mirror\\nodes\\_otr_line_composer.py:3008:    if \"\\n\" in raw.strip():\r\n  production_mirror\\nodes\\_otr_line_composer.py:3009:        return False, \"\"\r\n> production_mirror\\nodes\\_otr_line_composer.py:3010:    cleaned = clean_one_line(raw, max_chars=0)\r\n  production_mirror\\nodes\\_otr_line_composer.py:3011:    if not cleaned:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3012:        return False, \"\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:3021:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3022:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3023:def fallback_announcer_intro(script_brief: str) -> str:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3024:    \"\"\"Deterministic SIGNAL LOST opening line built from \r\nscript_brief.\r\n  production_mirror\\nodes\\_otr_line_composer.py:3025:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3026:    Fires when the intro LLM pass fails validation or has no \r\nbrief to\r\n  production_mirror\\nodes\\_otr_line_composer.py:3027:    work from. Pure string template -- the narrative frame must \r\nnever\r\n  production_mirror\\nodes\\_otr_line_composer.py:3028:    be missing. Never raises.\r\n  production_mirror\\nodes\\_otr_line_composer.py:3029:    \"\"\"\r\n> production_mirror\\nodes\\_otr_line_composer.py:3030:    brief = clean_one_line(script_brief or \"\", max_chars=200)\r\n> production_mirror\\nodes\\_otr_line_composer.py:3031:    if brief:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3032:        if brief[-1] not in \".!?\":\r\n> production_mirror\\nodes\\_otr_line_composer.py:3033:            brief += \".\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:3034:        return (\r\n> production_mirror\\nodes\\_otr_line_composer.py:3035:            f\"Good evening. This is SIGNAL LOST. Tonight: {brief} \r\n\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:3036:            f\"Stay with us.\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:3037:        )\r\n  production_mirror\\nodes\\_otr_line_composer.py:3042:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3043:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3044:def fallback_safe_open(safe_open_brief) -> str:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3045:    \"\"\"Deterministic SIGNAL LOST opening built from the \r\nSafeOpenBrief ONLY --\r\n> production_mirror\\nodes\\_otr_line_composer.py:3046:    never the script_brief (input starvation is the no-spoiler \r\nguarantee). Fires\r\n> production_mirror\\nodes\\_otr_line_composer.py:3047:    when the open LLM pass fails validation or the brief is thin. \r\nNever raises.\"\"\"\r\n> production_mirror\\nodes\\_otr_line_composer.py:3048:    sb = safe_open_brief\r\n> production_mirror\\nodes\\_otr_line_composer.py:3049:    setting = clean_one_line(str(getattr(sb, \"setting\", \"\") or \r\n\"\"), max_chars=120)\r\n> production_mirror\\nodes\\_otr_line_composer.py:3050:    tod = clean_one_line(str(getattr(sb, \"time_of_day\", \"\") or \r\n\"\"), max_chars=40)\r\n  production_mirror\\nodes\\_otr_line_composer.py:3051:    where = \", \".join(p for p in (tod, setting) if p)\r\n  production_mirror\\nodes\\_otr_line_composer.py:3052:    if where:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3062:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3063:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3064:def fallback_announcer_outro(news_close_brief: str) -> str:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3065:    \"\"\"Deterministic SIGNAL LOST closing line built from the \r\nclose brief.\r\n  production_mirror\\nodes\\_otr_line_composer.py:3066:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3067:    Fires when the outro LLM pass fails validation or has no \r\nbrief to\r\n  production_mirror\\nodes\\_otr_line_composer.py:3068:    work from. Pure string template -- the narrative frame must \r\nnever\r\n  production_mirror\\nodes\\_otr_line_composer.py:3069:    be missing. Never raises.\r\n  production_mirror\\nodes\\_otr_line_composer.py:3070:    \"\"\"\r\n> production_mirror\\nodes\\_otr_line_composer.py:3071:    close = clean_one_line(news_close_brief or \"\", max_chars=240)\r\n  production_mirror\\nodes\\_otr_line_composer.py:3072:    if close:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3073:        if close[-1] not in \".!?\":\r\n  production_mirror\\nodes\\_otr_line_composer.py:3080:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3081:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3082:def _resolved_outro_fallback(ending_change: str, \r\nnews_close_brief: str) -> str:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3083:    \"\"\"Deterministic resolved-ending outro (F3, story-engine v1).\r\n  production_mirror\\nodes\\_otr_line_composer.py:3084:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3085:    Used when the episode's dramatic question RESOLVED but the \r\nLLM keeps\r\n  production_mirror\\nodes\\_otr_line_composer.py:3086:    hedging (\"remains to be seen\", ...). States the \r\n``ending_change`` plainly\r\n> production_mirror\\nodes\\_otr_line_composer.py:3087:    with NO hedge phrase. Belt-and-suspenders: if the assembled \r\nline would\r\n  production_mirror\\nodes\\_otr_line_composer.py:3088:    still contain a hedge phrase, falls back to the plain close \r\ntemplate.\r\n  production_mirror\\nodes\\_otr_line_composer.py:3089:    Pure + deterministic; never raises.\r\n  production_mirror\\nodes\\_otr_line_composer.py:3090:    \"\"\"\r\n> production_mirror\\nodes\\_otr_line_composer.py:3091:    ec = clean_one_line(ending_change or \"\", max_chars=240)\r\n  production_mirror\\nodes\\_otr_line_composer.py:3092:    if not ec:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3093:        return fallback_announcer_outro(news_close_brief)\r\n  production_mirror\\nodes\\_otr_line_composer.py:3094:    if ec[-1] not in \".!?\":\r\n  production_mirror\\nodes\\_otr_line_composer.py:3095:        ec += \".\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:3100:        from _otr_dramatic_state import HEDGE_LIST as _HL  # \r\ntype: ignore\r\n  production_mirror\\nodes\\_otr_line_composer.py:3101:    if any(p in text.lower() for p in _HL):\r\n> production_mirror\\nodes\\_otr_line_composer.py:3102:        return fallback_announcer_outro(news_close_brief)\r\n  production_mirror\\nodes\\_otr_line_composer.py:3103:    return text\r\n  production_mirror\\nodes\\_otr_line_composer.py:3104:\r\n  production_mirror\\nodes\\_otr_line_composer.py:3107:    \"\"\"Run one creative-slot LLM call for an announcer pass.\r\n  production_mirror\\nodes\\_otr_line_composer.py:3108:\r\n> production_mirror\\nodes\\_otr_line_composer.py:3109:    Mirrors `compose_line`'s call convention: try the `stop=` \r\nkwarg\r\n  production_mirror\\nodes\\_otr_line_composer.py:3110:    form first, fall back to the no-`stop=` form for loaders that \r\ndo\r\n  production_mirror\\nodes\\_otr_line_composer.py:3111:    not accept it. Returns the raw string, or ``None`` if the call\r\n> production_mirror\\nodes\\_otr_line_composer.py:3112:    raised (the caller then drops to the deterministic fallback).\r\n  production_mirror\\nodes\\_otr_line_composer.py:3113:    \"\"\"\r\n  production_mirror\\nodes\\_otr_line_composer.py:3114:    # LLM slot: creative -- announcer dedicated-pass LLM call\r\n  production_mirror\\nodes\\_otr_line_composer.py:3119:                temperature=_BASE_TEMPERATURE,\r\n  production_mirror\\nodes\\_otr_line_composer.py:3120:                max_new_tokens=_ANNOUNCER_MAX_NEW_TOKENS,\r\n> production_mirror\\nodes\\_otr_line_composer.py:3121:                stop=list(_DEFAULT_STOP_STRINGS),\r\n  production_mirror\\nodes\\_otr_line_composer.py:3122:            )\r\n  production_mirror\\nodes\\_otr_line_composer.py:3123:        except Ty